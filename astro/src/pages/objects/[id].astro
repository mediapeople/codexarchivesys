---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import ObjectCard from '../../components/ObjectCard.astro';
import { getAllEntries } from '../../lib/archive';
import { computeRelatedEntries } from '../../lib/relations';
import { formatMediaLabel, getMediaItems, pickPrimaryMedia } from '../../lib/media';
import { formatDisplayTitle } from '../../lib/headline';
import { getAuthorInitials, getAuthorProfiles } from '../../lib/author';
import { buildObjectShareMeta } from '../../lib/shareMeta';
import { formatArchiveLongDate } from '../../lib/timeline';

export async function getStaticPaths() {
  const entries = await getAllEntries();
  return entries.map((entry) => ({
    params: { id: entry.data.id },
  }));
}

const allEntries = await getAllEntries();
const entry = allEntries.find((candidate) => candidate.data.id === Astro.params.id);

if (!entry) {
  throw new Error(`Missing entry for id: ${Astro.params.id}`);
}

const { Content } = await entry.render();
const related = computeRelatedEntries(entry, allEntries, 3);
const byId = new Map(allEntries.map((item) => [item.data.id, item]));
const mediaItems = getMediaItems(entry);
const primaryMedia = pickPrimaryMedia(mediaItems);
const secondaryMedia = primaryMedia
  ? mediaItems.filter((item) => item.src !== primaryMedia.src || item.role !== primaryMedia.role)
  : mediaItems;

const includedObjectsRaw = (entry.data as Record<string, unknown>).includedObjects;
const includedObjects = Array.isArray(includedObjectsRaw)
  ? includedObjectsRaw
      .map((item) => {
        if (
          item &&
          typeof item === 'object' &&
          'ref' in item &&
          'role' in item &&
          typeof (item as { ref: unknown }).ref === 'string' &&
          typeof (item as { role: unknown }).role === 'string'
        ) {
          return item as { ref: string; role: string };
        }
        return null;
      })
      .filter((item): item is { ref: string; role: string } => Boolean(item))
  : [];
const isNexusObject = entry.collection === 'nexus';
const sequenceItems = includedObjects.map((item, index) => {
  const target = byId.get(item.ref);
  return {
    index: index + 1,
    role: item.role,
    ref: item.ref,
    label: target?.data.title ? formatDisplayTitle(target.data.title) : item.ref,
    preview: target?.data.excerpt || '',
  };
});

function formatValue(value: unknown): string | null {
  if (value === undefined || value === null) {
    return null;
  }
  if (Array.isArray(value)) {
    if (value.length === 0) {
      return null;
    }
    if (typeof value[0] === 'object') {
      return null;
    }
    return value.map((item) => String(item)).join(', ');
  }
  const trimmed = String(value).trim();
  return trimmed ? trimmed : null;
}

const optionalFieldLabels: Record<string, string> = {
  project: 'Project',
  phase: 'Phase',
  context: 'Context',
  artifactType: 'Artifact Type',
  materials: 'Materials',
  dimensions: 'Dimensions',
  year: 'Year',
  version: 'Version',
  scope: 'Scope',
  systemArea: 'System Area',
  changeType: 'Change Type',
  lengthClass: 'Length Class',
  voice: 'Voice',
  origin: 'Origin',
  markers: 'Markers',
  themeStatement: 'Theme Statement',
  releaseType: 'Release Type',
};

const optionalFieldOrder = Object.keys(optionalFieldLabels);
const detailRows = optionalFieldOrder
  .map((field) => {
    const value = formatValue((entry.data as Record<string, unknown>)[field]);
    if (!value) {
      return null;
    }
    return {
      label: optionalFieldLabels[field],
      value,
    };
  })
  .filter((row): row is { label: string; value: string } => Boolean(row));

const readableDate = formatArchiveLongDate(entry.data.date);
const displayTitle = formatDisplayTitle(entry.data.title);
const shareMeta = buildObjectShareMeta({
  collection: entry.collection,
  title: displayTitle,
  excerpt: entry.data.excerpt,
  mediaItems,
  canonicalPath: `/objects/${entry.data.id}`,
});
const bodyClassRaw = (entry.data as Record<string, unknown>).bodyClass;
const bodyClass = typeof bodyClassRaw === 'string' ? bodyClassRaw : 'prose';
const objectFirstFlow = true;
const hasTaxonomy = entry.data.themes.length > 0 || entry.data.constellations.length > 0;
const contributors = getAuthorProfiles(entry);
const primaryAuthor = contributors[0];
const secondaryContributors = contributors.slice(1);
const authorInitials = getAuthorInitials(primaryAuthor.name);
const primaryDesignation = primaryAuthor.designation || primaryAuthor.role;
const nexusObjectContextQuery = isNexusObject
  ? `?from=nexus&nexus=${encodeURIComponent(entry.data.id)}`
  : '';
const defaultBackHref = isNexusObject ? '/nexus' : '/';
const defaultBackLabel = isNexusObject ? 'Back to nexus' : 'Back to feed';
---

<BaseLayout
  title={`${displayTitle} | Codex Archive`}
  description={shareMeta.description}
  canonicalPath={shareMeta.canonicalPath}
  socialImage={shareMeta.socialImage}
  socialType={shareMeta.socialType}
  twitterCard={shareMeta.twitterCard}
>
  <article class={`object-shell ${entry.collection} ${objectFirstFlow ? 'text-first-media' : ''}`}>
    <a
      class="back"
      href={defaultBackHref}
      data-context-back-link
      data-default-href={defaultBackHref}
      data-default-label={defaultBackLabel}
    >
      ← {defaultBackLabel}
    </a>

    <header class="object-head">
      <h1>{displayTitle}</h1>
      {entry.data.excerpt && <p class="excerpt">{entry.data.excerpt}</p>}
      <div class="object-type-callout">
        <TypeBadge type={entry.collection} />
      </div>
    </header>

    <section class={`body ${bodyClass}`}>
      <Content />
    </section>

    {sequenceItems.length > 0 && (
      <section class={`inclusion ${isNexusObject ? 'inclusion--nexus' : ''}`}>
        <h2>{isNexusObject ? 'Reading Sequence' : 'Nexus Stack'}</h2>
        <ol>
          {sequenceItems.map((item) => (
            <li>
              {isNexusObject ? (
                <>
                  <div class="seq-num">{String(item.index).padStart(2, '0')}</div>
                  <div class="seq-main">
                    <p class="role">{item.role}</p>
                    <a class="sequence-link" href={`/objects/${item.ref}${nexusObjectContextQuery}`}>
                      {item.label}
                    </a>
                    {item.preview && <p class="preview">{item.preview}</p>}
                  </div>
                </>
              ) : (
                <>
                  <span class="sequence-role">{item.role}</span>
                  <a class="sequence-link" href={`/objects/${item.ref}`}>{item.label}</a>
                </>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    {primaryMedia && (
      <section class="media-stage media-stage--supporting">
        <article class="media-primary">
          {primaryMedia.kind === 'image' && (
            <img
              src={primaryMedia.src}
              alt={primaryMedia.alt || `${entry.data.title} primary media`}
              data-expandable-image
              data-lightbox-caption={primaryMedia.caption || formatMediaLabel(primaryMedia)}
              loading="lazy"
              decoding="async"
              tabindex="0"
              role="button"
              aria-label="Expand image"
            />
          )}
          {primaryMedia.kind === 'video' && (
            <video controls preload="metadata" src={primaryMedia.src}>
              Your browser does not support the video element.
            </video>
          )}
          {primaryMedia.kind === 'audio' && (
            <div class="audio-shell">
              <audio controls preload="metadata" src={primaryMedia.src}>
                Your browser does not support the audio element.
              </audio>
            </div>
          )}
          <p class="media-meta">{formatMediaLabel(primaryMedia)}</p>
          {primaryMedia.caption && <p class="media-caption">{primaryMedia.caption}</p>}
        </article>

        {secondaryMedia.length > 0 && (
          <div class="media-rail">
            {secondaryMedia.map((item) => (
              <article class="media-item">
                {item.kind === 'image' && (
                  <img
                    src={item.src}
                    alt={item.alt || `${entry.data.title} media`}
                    data-expandable-image
                    data-lightbox-caption={item.caption || formatMediaLabel(item)}
                    loading="lazy"
                    decoding="async"
                    tabindex="0"
                    role="button"
                    aria-label="Expand image"
                  />
                )}
                {item.kind === 'video' && (
                  <video controls preload="metadata" src={item.src}>
                    Your browser does not support the video element.
                  </video>
                )}
                {item.kind === 'audio' && (
                  <div class="audio-shell">
                    <audio controls preload="metadata" src={item.src}>
                      Your browser does not support the audio element.
                    </audio>
                  </div>
                )}
                <p>{formatMediaLabel(item)}</p>
                {item.caption && <span>{item.caption}</span>}
              </article>
            ))}
          </div>
        )}
      </section>
    )}

    {detailRows.length > 0 && (
      <section class="detail-grid detail-grid--supporting">
        {detailRows.map((row) => (
          <article>
            <p>{row.label}</p>
            <strong>{row.value}</strong>
          </article>
        ))}
      </section>
    )}

    <footer class="source-signature source-signature--triptych">
      <article class="source-card">
        <div class="source-thumb" aria-hidden="true">
          {primaryAuthor.avatar ? (
            <img src={primaryAuthor.avatar} alt="" loading="lazy" decoding="async" />
          ) : (
            <span>{authorInitials}</span>
          )}
        </div>
        <div class="source-copy">
          <p class="source-label">Source</p>
          <p class="source-name">
            {primaryAuthor.name}
            {primaryDesignation && <span>, {primaryDesignation}</span>}
          </p>
        </div>
      </article>

      <section class="footer-unit footer-core-meta" aria-label="Object state">
        <p class="footer-unit-label">Object State</p>
        <dl>
          <div>
            <dt>Date</dt>
            <dd>{readableDate}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>{entry.data.status}</dd>
          </div>
          <div>
            <dt>Visibility</dt>
            <dd>{entry.data.visibility}</dd>
          </div>
        </dl>
      </section>

      <section class="footer-unit footer-taxonomy" aria-label="Object taxonomy">
        <p class="footer-unit-label">Taxonomy</p>
        {entry.data.themes.length > 0 && (
          <div class="footer-tag-group">
            <p class="footer-tag-label">Themes</p>
            <ul class="pills">
              {entry.data.themes.map((theme) => (
                <li>{theme}</li>
              ))}
            </ul>
          </div>
        )}
        {entry.data.constellations.length > 0 && (
          <div class="footer-tag-group">
            <p class="footer-tag-label">Constellation</p>
            <ul class="pills constellation">
              {entry.data.constellations.map((name) => (
                <li>{name}</li>
              ))}
            </ul>
          </div>
        )}
        {!hasTaxonomy && <p class="footer-empty">No taxonomy assigned.</p>}
      </section>

      {secondaryContributors.length > 0 && (
        <section class="co-authors-wrap">
          <p class="co-authors-label">Contributors</p>
          <ul class="co-authors">
            {secondaryContributors.map((person) => (
              <li>
                <strong>{person.name}</strong>
                {(person.designation || person.role) && <span>{person.designation || person.role}</span>}
              </li>
            ))}
          </ul>
        </section>
      )}
    </footer>
  </article>

  {related.length > 0 && (
    <section class="related">
      <header class="related-head">
        <h2>Related Objects</h2>
        <span>{related.length} objects</span>
      </header>
      <div class="cards">
        {related.map((hit) => (
          <ObjectCard entry={hit.entry} relationScore={hit.score} variant="related" />
        ))}
      </div>
    </section>
  )}

  <div class="image-lightbox" data-image-lightbox hidden aria-hidden="true">
    <div class="image-lightbox-topbar">
      <p class="image-lightbox-count" data-image-lightbox-count hidden aria-live="polite"></p>
      <button class="image-lightbox-close" type="button" data-image-lightbox-close aria-label="Close expanded image">
        Close
      </button>
    </div>
    <figure class="image-lightbox-frame">
      <button
        class="image-lightbox-nav image-lightbox-nav--prev"
        type="button"
        data-image-lightbox-prev
        aria-label="Show previous image"
        hidden
      >
        Prev
      </button>
      <img src="" alt="" data-image-lightbox-image />
      <button
        class="image-lightbox-nav image-lightbox-nav--next"
        type="button"
        data-image-lightbox-next
        aria-label="Show next image"
        hidden
      >
        Next
      </button>
      <figcaption data-image-lightbox-caption hidden></figcaption>
    </figure>
  </div>

  <script is:inline>
    (() => {
      const backLink = document.querySelector('[data-context-back-link]');
      if (!(backLink instanceof HTMLAnchorElement)) return;

      const safePath = (value) =>
        typeof value === 'string' && value.startsWith('/') && !value.startsWith('//');

      const setBackLink = (href, label) => {
        backLink.href = href;
        backLink.textContent = `← ${label}`;
      };

      const params = new URLSearchParams(window.location.search);
      const from = params.get('from');
      const nexusId = params.get('nexus');
      const explicitBack = params.get('back');

      if (safePath(explicitBack)) {
        const label = explicitBack.startsWith('/nexus') ? 'Back to nexus' : 'Back';
        setBackLink(explicitBack, label);
        return;
      }

      if (from === 'nexus') {
        if (nexusId && /^[a-z0-9._-]+$/i.test(nexusId)) {
          setBackLink(`/nexus/${encodeURIComponent(nexusId)}`, 'Back to nexus issue');
        } else {
          setBackLink('/nexus', 'Back to nexus');
        }
      }
    })();
  </script>

  <script is:inline>
    (() => {
      const lightbox = document.querySelector('[data-image-lightbox]');
      if (!(lightbox instanceof HTMLElement)) return;

      const lightboxImage = lightbox.querySelector('[data-image-lightbox-image]');
      const lightboxCaption = lightbox.querySelector('[data-image-lightbox-caption]');
      const lightboxCount = lightbox.querySelector('[data-image-lightbox-count]');
      const closeButton = lightbox.querySelector('[data-image-lightbox-close]');
      const prevButton = lightbox.querySelector('[data-image-lightbox-prev]');
      const nextButton = lightbox.querySelector('[data-image-lightbox-next]');
      const lightboxFrame = lightbox.querySelector('.image-lightbox-frame');
      if (!(lightboxImage instanceof HTMLImageElement)) return;
      if (!(lightboxCaption instanceof HTMLElement)) return;
      if (!(lightboxCount instanceof HTMLElement)) return;
      if (!(prevButton instanceof HTMLButtonElement)) return;
      if (!(nextButton instanceof HTMLButtonElement)) return;
      if (!(lightboxFrame instanceof HTMLElement)) return;

      const selectors = '.object-shell .media-stage img[data-expandable-image], .object-shell .body img';
      const candidates = Array.from(document.querySelectorAll(selectors)).filter(
        (node) => node instanceof HTMLImageElement
      );
      if (!candidates.length) return;

      let lastFocusedImage = null;
      let previousOverflow = '';
      let activeIndex = -1;
      let touchStartX = 0;
      let touchStartY = 0;
      let isTransitioning = false;
      let transitionSwapTimeout = 0;
      let transitionCleanupTimeout = 0;
      let lastGestureNavigationAt = 0;
      const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      const mobileTapNavigationQuery = window.matchMedia('(max-width: 560px)');

      const clearTransitionTimers = () => {
        if (transitionSwapTimeout) {
          window.clearTimeout(transitionSwapTimeout);
          transitionSwapTimeout = 0;
        }

        if (transitionCleanupTimeout) {
          window.clearTimeout(transitionCleanupTimeout);
          transitionCleanupTimeout = 0;
        }
      };

      const clearTransitionState = () => {
        clearTransitionTimers();
        isTransitioning = false;
        lightboxFrame.classList.remove('is-transitioning-out', 'is-transitioning-in', 'is-forward', 'is-backward');
      };

      const syncNavState = () => {
        const hasGallery = candidates.length > 1;
        const atStart = activeIndex <= 0;
        const atEnd = activeIndex >= candidates.length - 1;

        lightbox.classList.toggle('is-gallery', hasGallery);
        prevButton.hidden = !hasGallery;
        nextButton.hidden = !hasGallery;
        prevButton.disabled = !hasGallery || atStart;
        nextButton.disabled = !hasGallery || atEnd;

        if (hasGallery && activeIndex >= 0) {
          lightboxCount.textContent = `${activeIndex + 1} / ${candidates.length}`;
          lightboxCount.hidden = false;
        } else {
          lightboxCount.textContent = '';
          lightboxCount.hidden = true;
          }
        };

      const applyImageAtIndex = (index) => {
        const imageEl = candidates[index];
        if (!(imageEl instanceof HTMLImageElement)) return;

        const source = imageEl.currentSrc || imageEl.src;
        if (!source) return;

        activeIndex = index;
        lightboxImage.src = source;
        lightboxImage.alt = imageEl.alt || 'Expanded image';

        const caption = imageEl.getAttribute('data-lightbox-caption') || imageEl.alt || '';
        if (caption) {
          lightboxCaption.textContent = caption;
          lightboxCaption.hidden = false;
        } else {
          lightboxCaption.textContent = '';
          lightboxCaption.hidden = true;
        }

        syncNavState();
      };

      const renderImageAtIndex = (index, direction = 0) => {
        const imageEl = candidates[index];
        if (!(imageEl instanceof HTMLImageElement)) return;

        const shouldAnimate =
          direction !== 0 &&
          !lightbox.hidden &&
          !reducedMotionQuery.matches;

        if (!shouldAnimate) {
          clearTransitionState();
          applyImageAtIndex(index);
          return;
        }

        clearTransitionState();
        isTransitioning = true;
        lightboxFrame.classList.add('is-transitioning-out', direction > 0 ? 'is-forward' : 'is-backward');

        transitionSwapTimeout = window.setTimeout(() => {
          applyImageAtIndex(index);
          lightboxFrame.classList.remove('is-transitioning-out');
          lightboxFrame.classList.add('is-transitioning-in');

          transitionCleanupTimeout = window.setTimeout(() => {
            clearTransitionState();
          }, 240);
        }, 120);
      };

      const stepGallery = (direction) => {
        if (activeIndex < 0 || isTransitioning) return;

        const nextIndex = activeIndex + direction;
        if (nextIndex < 0 || nextIndex >= candidates.length) return;

        renderImageAtIndex(nextIndex, direction);
      };

      const closeLightbox = () => {
        if (lightbox.hidden) return;
        lightbox.hidden = true;
        lightbox.setAttribute('aria-hidden', 'true');
        lightboxImage.removeAttribute('src');
        lightboxImage.removeAttribute('alt');
        lightboxCaption.textContent = '';
        lightboxCaption.hidden = true;
        lightboxCount.textContent = '';
        lightboxCount.hidden = true;
        lightbox.classList.remove('is-gallery');
        clearTransitionState();
        activeIndex = -1;
        document.body.style.overflow = previousOverflow;
        if (lastFocusedImage instanceof HTMLElement) {
          lastFocusedImage.focus();
        }
      };

      const openLightbox = (imageEl) => {
        const index = candidates.indexOf(imageEl);
        if (index === -1) return;

        previousOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        lastFocusedImage = imageEl;
        clearTransitionState();
        renderImageAtIndex(index);

        lightbox.hidden = false;
        lightbox.setAttribute('aria-hidden', 'false');
      };

      candidates.forEach((imageEl) => {
        if (!(imageEl instanceof HTMLImageElement)) return;
        if (imageEl.closest('a')) return;

        imageEl.classList.add('expandable-image');
        if (!imageEl.hasAttribute('tabindex')) {
          imageEl.setAttribute('tabindex', '0');
        }
        if (!imageEl.hasAttribute('role')) {
          imageEl.setAttribute('role', 'button');
        }
        if (!imageEl.getAttribute('aria-label')) {
          imageEl.setAttribute('aria-label', 'Expand image');
        }

        imageEl.addEventListener('click', () => openLightbox(imageEl));
        imageEl.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            openLightbox(imageEl);
          }
        });
      });

      closeButton?.addEventListener('click', closeLightbox);
      prevButton.addEventListener('click', () => stepGallery(-1));
      nextButton.addEventListener('click', () => stepGallery(1));

      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) {
          closeLightbox();
        }
      });

      lightboxFrame.addEventListener(
        'touchstart',
        (event) => {
          const touch = event.touches[0];
          if (!touch) return;
          touchStartX = touch.clientX;
          touchStartY = touch.clientY;
        },
        { passive: true }
      );

      lightboxFrame.addEventListener(
        'touchend',
        (event) => {
          const touch = event.changedTouches[0];
          if (!touch) return;

          const deltaX = touch.clientX - touchStartX;
          const deltaY = touch.clientY - touchStartY;
          if (Math.abs(deltaX) < 48 || Math.abs(deltaX) <= Math.abs(deltaY)) return;

          lastGestureNavigationAt = Date.now();
          if (deltaX < 0) {
            stepGallery(1);
          } else {
            stepGallery(-1);
          }
        },
        { passive: true }
      );

      lightboxFrame.addEventListener('click', (event) => {
        if (lightbox.hidden) return;
        if (!mobileTapNavigationQuery.matches) return;
        if (candidates.length <= 1 || isTransitioning) return;
        if (Date.now() - lastGestureNavigationAt < 360) return;
        if (event.target instanceof HTMLElement && event.target.closest('button, a, figcaption')) return;

        const captionRect = lightboxCaption.hidden ? null : lightboxCaption.getBoundingClientRect();
        if (captionRect && event.clientY >= captionRect.top) return;

        const frameRect = lightboxFrame.getBoundingClientRect();
        const midpoint = frameRect.left + frameRect.width / 2;
        if (event.clientX < midpoint) {
          stepGallery(-1);
        } else {
          stepGallery(1);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeLightbox();
          return;
        }

        if (lightbox.hidden) return;

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          stepGallery(-1);
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          stepGallery(1);
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .object-shell {
    border-bottom: none;
    padding: 4rem 0 5.2rem;
    background: transparent;
    --table-line: rgba(164, 134, 97, 0.28);
    --table-line-soft: rgba(164, 134, 97, 0.2);
    --table-fill: rgba(255, 255, 255, 0.01);
  }

  .back {
    display: inline-block;
    color: var(--mid);
    text-decoration: none;
    margin-bottom: 1.1rem;
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-ui);
    border-bottom: 1px solid var(--line);
    padding: 0 0 0.2rem;
    transition: 0.12s;
  }

  .back:hover {
    color: var(--star);
    border-color: var(--mid);
  }

  .object-head > :global(.type-badge) {
    margin-top: 0.1rem;
  }

  .object-type-callout {
    margin-top: 0.38rem;
    margin-bottom: 0.34rem;
  }

  .object-type-callout :global(.type-badge) {
    background: rgba(196, 98, 58, 0.06);
    border-color: rgba(196, 98, 58, 0.36);
    color: rgba(223, 171, 146, 0.92);
  }

  .object-head h1 {
    margin: 0.85rem 0 1.15rem;
  }

  .object-shell.scroll .object-head h1,
  .object-shell.fieldlog .object-head h1,
  .object-shell.codex .object-head h1 {
    margin-bottom: 1.85rem;
    line-height: 1.3;
    max-width: 60%;
  }

  .excerpt {
    margin: 0;
    color: var(--text-body);
    font-size: 1.26rem;
    line-height: 1.74;
    font-style: normal;
    max-width: 44ch;
  }

  .core-meta {
    margin: 2.8rem 0 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--table-line);
    border-bottom: 1px solid var(--table-line-soft);
    padding: 1.15rem 0 1.02rem;
    background: transparent;
  }

  .core-meta div {
    min-height: 0;
    padding: 0 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    position: relative;
  }

  .core-meta div + div {
