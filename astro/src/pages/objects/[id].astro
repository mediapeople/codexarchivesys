---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import ObjectCard from '../../components/ObjectCard.astro';
import { getAllEntries } from '../../lib/archive';
import { computeRelatedEntries } from '../../lib/relations';
import { formatMediaLabel, getMediaItems, pickPrimaryMedia } from '../../lib/media';
import { formatDisplayTitle } from '../../lib/headline';
import { getAuthorInitials, getAuthorProfiles } from '../../lib/author';

export async function getStaticPaths() {
  const entries = await getAllEntries();
  return entries.map((entry) => ({
    params: { id: entry.data.id },
  }));
}

const allEntries = await getAllEntries();
const entry = allEntries.find((candidate) => candidate.data.id === Astro.params.id);

if (!entry) {
  throw new Error(`Missing entry for id: ${Astro.params.id}`);
}

const { Content } = await entry.render();
const related = computeRelatedEntries(entry, allEntries, 3);
const byId = new Map(allEntries.map((item) => [item.data.id, item]));
const mediaItems = getMediaItems(entry);
const primaryMedia = pickPrimaryMedia(mediaItems);
const secondaryMedia = primaryMedia
  ? mediaItems.filter((item) => item.src !== primaryMedia.src || item.role !== primaryMedia.role)
  : mediaItems;

const includedObjectsRaw = (entry.data as Record<string, unknown>).includedObjects;
const includedObjects = Array.isArray(includedObjectsRaw)
  ? includedObjectsRaw
      .map((item) => {
        if (
          item &&
          typeof item === 'object' &&
          'ref' in item &&
          'role' in item &&
          typeof (item as { ref: unknown }).ref === 'string' &&
          typeof (item as { role: unknown }).role === 'string'
        ) {
          return item as { ref: string; role: string };
        }
        return null;
      })
      .filter((item): item is { ref: string; role: string } => Boolean(item))
  : [];

function formatValue(value: unknown): string | null {
  if (value === undefined || value === null) {
    return null;
  }
  if (Array.isArray(value)) {
    if (value.length === 0) {
      return null;
    }
    if (typeof value[0] === 'object') {
      return null;
    }
    return value.map((item) => String(item)).join(', ');
  }
  const trimmed = String(value).trim();
  return trimmed ? trimmed : null;
}

const optionalFieldLabels: Record<string, string> = {
  project: 'Project',
  phase: 'Phase',
  context: 'Context',
  artifactType: 'Artifact Type',
  materials: 'Materials',
  dimensions: 'Dimensions',
  year: 'Year',
  version: 'Version',
  scope: 'Scope',
  systemArea: 'System Area',
  changeType: 'Change Type',
  lengthClass: 'Length Class',
  voice: 'Voice',
  origin: 'Origin',
  markers: 'Markers',
  themeStatement: 'Theme Statement',
  releaseType: 'Release Type',
};

const optionalFieldOrder = Object.keys(optionalFieldLabels);
const detailRows = optionalFieldOrder
  .map((field) => {
    const value = formatValue((entry.data as Record<string, unknown>)[field]);
    if (!value) {
      return null;
    }
    return {
      label: optionalFieldLabels[field],
      value,
    };
  })
  .filter((row): row is { label: string; value: string } => Boolean(row));

const readableDate = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const displayTitle = formatDisplayTitle(entry.data.title);
const bodyClassRaw = (entry.data as Record<string, unknown>).bodyClass;
const bodyClass = typeof bodyClassRaw === 'string' ? bodyClassRaw : 'prose';
const objectFirstFlow = true;
const hasTaxonomy = entry.data.themes.length > 0 || entry.data.constellations.length > 0;
const contributors = getAuthorProfiles(entry);
const primaryAuthor = contributors[0];
const secondaryContributors = contributors.slice(1);
const authorInitials = getAuthorInitials(primaryAuthor.name);
const primaryDesignation = primaryAuthor.designation || primaryAuthor.role;
---

<BaseLayout title={`${displayTitle} | Codex Archive`}>
  <article class={`object-shell ${entry.collection} ${objectFirstFlow ? 'text-first-media' : ''}`}>
    <a class="back" href="/">← Back to feed</a>

    <header class="object-head">
      <h1>{displayTitle}</h1>
      {entry.data.excerpt && <p class="excerpt">{entry.data.excerpt}</p>}
      <div class="object-type-callout">
        <TypeBadge type={entry.collection} />
      </div>
    </header>

    <section class={`body ${bodyClass}`}>
      <Content />
    </section>

    {includedObjects.length > 0 && (
      <section class="inclusion">
        <h2>Nexus Sequence</h2>
        <ol>
          {includedObjects.map((item) => {
            const target = byId.get(item.ref);
            const label = target?.data.title ? formatDisplayTitle(target.data.title) : item.ref;
            return (
              <li>
                <span class="sequence-role">{item.role}</span>
                <a class="sequence-link" href={`/objects/${item.ref}`}>{label}</a>
              </li>
            );
          })}
        </ol>
      </section>
    )}

    {primaryMedia && (
      <section class="media-stage media-stage--supporting">
        <article class="media-primary">
          {primaryMedia.kind === 'image' && (
            <img
              src={primaryMedia.src}
              alt={primaryMedia.alt || `${entry.data.title} primary media`}
              loading="lazy"
              decoding="async"
            />
          )}
          {primaryMedia.kind === 'video' && (
            <video controls preload="metadata" src={primaryMedia.src}>
              Your browser does not support the video element.
            </video>
          )}
          {primaryMedia.kind === 'audio' && (
            <div class="audio-shell">
              <audio controls preload="metadata" src={primaryMedia.src}>
                Your browser does not support the audio element.
              </audio>
            </div>
          )}
          <p class="media-meta">{formatMediaLabel(primaryMedia)}</p>
          {primaryMedia.caption && <p class="media-caption">{primaryMedia.caption}</p>}
        </article>

        {secondaryMedia.length > 0 && (
          <div class="media-rail">
            {secondaryMedia.map((item) => (
              <article class="media-item">
                {item.kind === 'image' && (
                  <img
                    src={item.src}
                    alt={item.alt || `${entry.data.title} media`}
                    loading="lazy"
                    decoding="async"
                  />
                )}
                {item.kind === 'video' && (
                  <video controls preload="metadata" src={item.src}>
                    Your browser does not support the video element.
                  </video>
                )}
                {item.kind === 'audio' && (
                  <div class="audio-shell">
                    <audio controls preload="metadata" src={item.src}>
                      Your browser does not support the audio element.
                    </audio>
                  </div>
                )}
                <p>{formatMediaLabel(item)}</p>
                {item.caption && <span>{item.caption}</span>}
              </article>
            ))}
          </div>
        )}
      </section>
    )}

    {detailRows.length > 0 && (
      <section class="detail-grid detail-grid--supporting">
        {detailRows.map((row) => (
          <article>
            <p>{row.label}</p>
            <strong>{row.value}</strong>
          </article>
        ))}
      </section>
    )}

    <footer class="source-signature source-signature--triptych">
      <article class="source-card">
        <div class="source-thumb" aria-hidden="true">
          {primaryAuthor.avatar ? (
            <img src={primaryAuthor.avatar} alt="" loading="lazy" decoding="async" />
          ) : (
            <span>{authorInitials}</span>
          )}
        </div>
        <div class="source-copy">
          <p class="source-label">Source</p>
          <p class="source-name">
            {primaryAuthor.name}
            {primaryDesignation && <span>, {primaryDesignation}</span>}
          </p>
          {primaryAuthor.handle && <p class="source-handle">{primaryAuthor.handle}</p>}
          {primaryAuthor.bio && <p class="source-bio">{primaryAuthor.bio}</p>}
        </div>
      </article>

      <section class="footer-unit footer-core-meta" aria-label="Object state">
        <p class="footer-unit-label">Object State</p>
        <dl>
          <div>
            <dt>Date</dt>
            <dd>{readableDate}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>{entry.data.status}</dd>
          </div>
          <div>
            <dt>Visibility</dt>
            <dd>{entry.data.visibility}</dd>
          </div>
        </dl>
      </section>

      <section class="footer-unit footer-taxonomy" aria-label="Object taxonomy">
        <p class="footer-unit-label">Taxonomy</p>
        {entry.data.themes.length > 0 && (
          <div class="footer-tag-group">
            <p class="footer-tag-label">Themes</p>
            <ul class="pills">
              {entry.data.themes.map((theme) => (
                <li>{theme}</li>
              ))}
            </ul>
          </div>
        )}
        {entry.data.constellations.length > 0 && (
          <div class="footer-tag-group">
            <p class="footer-tag-label">Constellation</p>
            <ul class="pills constellation">
              {entry.data.constellations.map((name) => (
                <li>{name}</li>
              ))}
            </ul>
          </div>
        )}
        {!hasTaxonomy && <p class="footer-empty">No taxonomy assigned.</p>}
      </section>

      {secondaryContributors.length > 0 && (
        <section class="co-authors-wrap">
          <p class="co-authors-label">Contributors</p>
          <ul class="co-authors">
            {secondaryContributors.map((person) => (
              <li>
                <strong>{person.name}</strong>
                {(person.designation || person.role) && <span>{person.designation || person.role}</span>}
              </li>
            ))}
          </ul>
        </section>
      )}
    </footer>
  </article>

  {related.length > 0 && (
    <section class="related">
      <header class="related-head">
        <h2>Related Objects</h2>
        <span>{related.length} objects</span>
      </header>
      <div class="cards">
        {related.map((hit) => (
          <ObjectCard entry={hit.entry} relationScore={hit.score} variant="related" />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .object-shell {
    border-bottom: none;
    padding: 4rem 0 5.2rem;
    background: transparent;
    --table-line: rgba(164, 134, 97, 0.28);
    --table-line-soft: rgba(164, 134, 97, 0.2);
    --table-fill: rgba(255, 255, 255, 0.01);
  }

  .back {
    display: inline-block;
    color: var(--mid);
    text-decoration: none;
    margin-bottom: 1.1rem;
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-ui);
    border-bottom: 1px solid var(--line);
    padding: 0 0 0.2rem;
    transition: 0.12s;
  }

  .back:hover {
    color: var(--star);
    border-color: var(--mid);
  }

  .object-head > :global(.type-badge) {
    margin-top: 0.1rem;
  }

  .object-type-callout {
    margin-top: 0.38rem;
    margin-bottom: 0.34rem;
  }

  .object-type-callout :global(.type-badge) {
    background: rgba(196, 98, 58, 0.06);
    border-color: rgba(196, 98, 58, 0.36);
    color: rgba(223, 171, 146, 0.92);
  }

  .object-head h1 {
    margin: 0.85rem 0 1.15rem;
    color: var(--star);
    line-height: 1.1;
    font-size: clamp(2.7rem, 5.5vw, 4.9rem);
    font-style: normal;
    font-weight: 700;
    letter-spacing: var(--ls-display);
  }

  .excerpt {
    margin: 0;
    color: var(--text-body);
    font-size: 1.26rem;
    line-height: 1.74;
    font-style: normal;
    max-width: 44ch;
  }

  .core-meta {
    margin: 2.8rem 0 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--table-line);
    border-bottom: 1px solid var(--table-line-soft);
    padding: 1.15rem 0 1.02rem;
    background: transparent;
  }

  .core-meta div {
    min-height: 0;
    padding: 0 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    position: relative;
  }

  .core-meta div + div {
    padding-left: 1.08rem;
  }

  .core-meta div:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 0.25rem;
    right: 0;
    width: 1px;
    height: calc(100% - 0.5rem);
    background: var(--table-line-soft);
  }

  .core-meta dt {
    margin: 0 0 0.4rem;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--ls-ui-wide);
  }

  .core-meta dd {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.98rem;
    line-height: 1.4;
    letter-spacing: 0.01em;
    font-weight: 400;
  }

  .meta-tags {
    margin-top: 1.06rem;
  }

  .meta-tags + .meta-tags {
    margin-top: 0.72rem;
  }

  .meta-tags-label {
    margin: 0 0 0.24rem;
    color: rgba(164, 134, 97, 0.9);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    line-height: 1.2;
  }

  .pills {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.52rem 1rem;
  }

  .pills li {
    border: none;
    color: var(--ash);
    font-family: var(--font-ui);
    padding: 0;
    font-size: 12px;
    letter-spacing: var(--ls-ui);
    text-transform: lowercase;
    line-height: 1.35;
  }

  .pills li::before {
    content: '#';
    color: rgba(164, 134, 97, 0.82);
    margin-right: 0.24rem;
  }

  .constellation li {
    color: var(--gold);
    text-transform: none;
  }

  .constellation li::before {
    content: '↳';
    color: rgba(201, 150, 58, 0.82);
    margin-right: 0.34rem;
  }

  .source-signature {
    margin-top: 4.6rem;
    padding-top: 1.65rem;
    max-width: min(420px, 100%);
  }

  .source-signature--triptych {
    margin-top: 3.2rem;
    padding-top: 1.45rem;
    max-width: min(1120px, 100%);
    border-top: 1px solid var(--table-line-soft);
    display: grid;
    grid-template-columns: minmax(260px, 1.1fr) minmax(220px, 0.85fr) minmax(260px, 1fr);
    gap: 1rem 1.45rem;
    align-items: start;
    --meta-font-label: var(--font-ui);
    --meta-font-value: var(--font-body);
  }

  .source-signature--triptych .source-card {
    max-width: none;
  }

  .source-signature--triptych .source-label,
  .source-signature--triptych .footer-unit-label,
  .source-signature--triptych .footer-core-meta dt,
  .source-signature--triptych .footer-tag-label {
    font-family: var(--meta-font-label);
    letter-spacing: var(--ls-ui-wide);
  }

  .source-signature--triptych .source-name,
  .source-signature--triptych .footer-core-meta dd,
  .source-signature--triptych .source-bio {
    font-family: var(--meta-font-value);
  }

  .source-signature--triptych .source-name {
    font-size: clamp(1.02rem, 1.6vw, 1.18rem);
    font-weight: 600;
    line-height: 1.34;
    letter-spacing: -0.006em;
  }

  .source-signature--triptych .source-name span {
    font-family: var(--meta-font-label);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
  }

  .source-signature--triptych .source-handle {
    font-family: var(--meta-font-label);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
  }

  .source-signature--triptych .source-bio {
    font-size: 1.02rem;
    line-height: 1.58;
    letter-spacing: -0.003em;
    max-width: 34ch;
  }

  .source-signature--triptych .source-bio::before {
    font-family: var(--meta-font-value);
    font-size: 1.48rem;
  }

  .footer-unit {
    min-width: 0;
  }

  .footer-unit-label {
    margin: 0 0 0.58rem;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    line-height: 1.2;
  }

  .footer-core-meta dl {
    margin: 0;
    display: grid;
    gap: 0.46rem;
  }

  .footer-core-meta div {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.62rem;
    align-items: baseline;
  }

  .footer-core-meta dt {
    margin: 0;
    color: rgba(164, 134, 97, 0.88);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    line-height: 1.2;
  }

  .footer-core-meta dd {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .footer-tag-group + .footer-tag-group {
    margin-top: 0.58rem;
  }

  .footer-tag-label {
    margin: 0 0 0.2rem;
    color: rgba(164, 134, 97, 0.88);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    line-height: 1.2;
  }

  .footer-empty {
    margin: 0.12rem 0 0;
    color: var(--ghost);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    text-transform: lowercase;
    line-height: 1.35;
  }

  .source-signature--triptych .footer-taxonomy .pills {
    gap: 0.34rem 0.74rem;
  }

  .source-signature--triptych .footer-taxonomy .pills li {
    font-family: var(--meta-font-label);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
  }

  .source-card {
    display: block;
    padding: 0;
    background: transparent;
    max-width: min(420px, 100%);
  }

  .source-card::after {
    content: '';
    display: block;
    clear: both;
  }

  .source-thumb {
    width: clamp(2.25rem, 4vw, 4rem);
    height: clamp(2.25rem, 4vw, 4rem);
    max-width: 64px;
    max-height: 64px;
    float: left;
    margin-right: 0.85rem;
    margin-top: 0.05rem;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--table-line);
    background: rgba(255, 255, 255, 0.03);
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .source-thumb img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .source-thumb span {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    color: var(--mid);
    letter-spacing: 0.11em;
  }

  .source-copy {
    overflow: hidden;
    min-width: 0;
    padding-top: 0.02rem;
  }

  .source-label {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    line-height: 1.3;
  }

  .source-name {
    margin: 0.2rem 0 0;
    color: var(--star);
    font-size: 1rem;
    line-height: 1.4;
    font-style: normal;
  }

  .source-name span {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .source-handle {
    margin: 0.26rem 0 0;
    color: var(--ghost);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    line-height: 1.3;
  }

  .source-bio {
    margin: 0.74rem 0 0;
    color: var(--text-body);
    font-size: 1.08rem;
    line-height: 1.66;
    font-style: italic;
    letter-spacing: -0.004em;
    max-width: 30ch;
    padding-left: 0.68rem;
    border-left: none;
    position: relative;
  }

  .source-bio::before {
    content: '“';
    position: absolute;
    left: 0;
    top: -0.46rem;
    color: rgba(201, 150, 58, 0.62);
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
  }

  .co-authors-wrap {
    margin-top: 0.82rem;
    max-width: min(420px, 100%);
  }

  .source-signature--triptych .co-authors-wrap {
    grid-column: 1 / -1;
    max-width: none;
    margin-top: 0.25rem;
  }

  .co-authors-label {
    margin: 0 0 0.45rem;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .co-authors {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .co-authors li {
    border: none;
    padding: 0;
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    color: var(--mid);
    display: inline-flex;
    gap: 0.36rem;
    align-items: baseline;
  }

  .co-authors li::before {
    content: '•';
    color: rgba(164, 134, 97, 0.72);
    margin-right: 0.16rem;
  }

  .co-authors strong {
    color: var(--bone);
    font-weight: 600;
  }

  .detail-grid {
    margin: 2.3rem 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0;
    border: 1px solid var(--table-line);
    background: var(--table-fill);
  }

  .detail-grid article {
    border-right: 1px solid var(--table-line-soft);
    border-bottom: 1px solid var(--table-line-soft);
    margin-right: -1px;
    margin-bottom: -1px;
    padding: 1.02rem 1.2rem 1.16rem;
    background: transparent;
  }

  .detail-grid p {
    margin: 0 0 0.34rem;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--ls-ui-wide);
  }

  .detail-grid strong {
    color: var(--bone);
    font-size: 1.08rem;
    line-height: 1.58;
    font-weight: 600;
  }

  .detail-grid--supporting {
    margin: 2.45rem 0 2.25rem;
  }

  .media-stage {
    margin-top: 4.2rem;
    display: grid;
    gap: 2rem;
    max-width: min(1120px, 100%);
  }

  .media-primary {
    padding: 0.7rem 0 0.8rem;
    background: transparent;
  }

  .media-primary img,
  .media-primary video {
    width: auto;
    max-width: 100%;
    max-height: min(68vh, 820px);
