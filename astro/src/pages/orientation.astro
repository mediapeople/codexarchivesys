---
import BaseLayout from '../layouts/BaseLayout.astro';
import { COLLECTIONS, getAllEntries } from '../lib/archive';
import { getDefaultSourceProfile } from '../lib/sourceProfiles';
import TypeBadge from '../components/TypeBadge.astro';
import { formatArchiveDate } from '../lib/timeline';

const entries = await getAllEntries();
const operator = getDefaultSourceProfile();
const operatorExpandedBio = operator.orientationBio || operator.bio || '';
const operatorNoteTitle = operator.orientationNoteTitle || '';
const operatorNoteParagraphs = operator.orientationNoteParagraphs || [];
const operatorNoteSignature = operator.orientationNoteSignature || '';
const operatorLinks = operator.links || [];

const typeCounts = COLLECTIONS.map((type) => ({
  type,
  count: entries.filter((entry) => entry.collection === type).length,
})).filter((item) => item.count > 0);

const typeDefinitionMap: Record<
  (typeof COLLECTIONS)[number],
  {
    description: string;
  }
> = {
  scroll: {
    description: 'Extended writing that carries context, sequence, and sustained argument.',
  },
  loremap: {
    description: 'Place-anchored field definitions that map terrain, symbolic layers, and recurring geologic or civic signal.',
  },
  artifact: {
    description: 'Physical or digital outputs that document what was made and how it holds up.',
  },
  fieldlog: {
    description: 'Dated records of system condition, constraints, and directional adjustments.',
  },
  codex: {
    description: 'Core references that define stable standards for structure and publishing.',
  },
  fragment: {
    description: 'Small units of meaning meant to stay useful alone and expandable later.',
  },
  nexus: {
    description: 'Curated reading chains that connect objects into coherent narrative movement.',
  },
  signal: {
    description: 'Short, high-clarity statements intended for immediate interpretation and use.',
  },
};

const activeConstellations = [...new Set(entries.flatMap((entry) => entry.data.constellations))].sort(
  (a, b) => a.localeCompare(b)
);

const constellationBlueprint = [
  {
    name: 'Cascade Psalms',
    description: 'Compression, pressure, and what survives weight.',
    scope: 'Signal under load',
    tone: 'cascade',
  },
  {
    name: 'Maintenance Psalms',
    description: 'Continuing, Tuesdays, and the practice of keeping on.',
    scope: 'Durable routines',
    tone: 'maintenance',
  },
  {
    name: 'Archaeological Objects',
    description: 'Physical artifacts, constructed works, and recovered material.',
    scope: 'Material evidence',
    tone: 'archaeology',
  },
] as const;

const constellationCards = constellationBlueprint.map((item) => ({
  ...item,
  count: entries.filter((entry) => entry.data.constellations.includes(item.name)).length,
}));

const latestEntry = entries[0] || null;
const latestDate = latestEntry ? formatArchiveDate(latestEntry.data.date) : null;

const coreOperatingRule =
  'The system optimizes for immediate orientation and dependable live publishing while preserving object-first reading quality.';

const stabilityRules = ['schema slow', 'objects fast', 'relations growing'];

const orientationMapNodes: Array<{
  type: (typeof COLLECTIONS)[number];
  x: string;
  y: string;
  note: string;
}> = [
  { type: 'codex', x: '14%', y: '16%', note: 'governance spine' },
  { type: 'loremap', x: '28%', y: '16%', note: 'terrain field' },
  { type: 'fieldlog', x: '36%', y: '32%', note: 'runtime record' },
  { type: 'fragment', x: '21%', y: '62%', note: 'seed capture' },
  { type: 'signal', x: '50%', y: '18%', note: 'public signal' },
  { type: 'nexus', x: '67%', y: '42%', note: 'sequence layer' },
  { type: 'scroll', x: '46%', y: '72%', note: 'longform context' },
  { type: 'artifact', x: '84%', y: '70%', note: 'material proof' },
];

const fieldContractRows = [
  {
    field: 'Title',
    renders: 'Feed / Object / Graph',
    owner: 'Operator',
    role: 'Names the claim and object intent.',
  },
  {
    field: 'Excerpt',
    renders: 'Feed / Search / Share',
    owner: 'Operator',
    role: 'Carries a standalone promise.',
  },
  {
    field: 'Constellation',
    renders: 'Object / Graph',
    owner: 'Operator',
    role: 'Anchors relation and retrieval.',
  },
  {
    field: 'Related Objects',
    renders: 'Object / Nexus',
    owner: 'System + Operator',
    role: 'Maintains continuity across releases.',
  },
  {
    field: 'Location / Geo',
    renders: 'Object / Loremap / Spatial surfaces',
    owner: 'Operator',
    role: 'Grounds place-aware retrieval and terrain context.',
  },
] as const;
---

<BaseLayout
  title="Orientation | Codex Archive"
  description="Archaeological mythology in practice: a living archive of scrolls, collages, codices, and field logs."
  canonicalPath="/orientation"
>
  <section class="orientation-hero page-hero">
    <p class="page-hero-eyebrow">Orientation</p>
    <h1 class="page-hero-title">Archaeological Mythology in Practice</h1>
    <p class="page-hero-sub">
      A living archive of scrolls, collages, codices, and field logs — excavating transmissible wisdom
      from lived experience, cultural artifacts, and creative ordeal.
    </p>
    <div class="hero-stats">
      <article class="page-plate">
        <strong>{entries.length}</strong>
        <span>Objects indexed</span>
      </article>
      <article class="page-plate">
        <strong>{typeCounts.length}</strong>
        <span>Types active</span>
      </article>
      <article class="page-plate">
        <strong>{activeConstellations.length}</strong>
        <span>Constellations active</span>
      </article>
      {latestDate && (
        <article class="page-plate">
          <strong>{latestDate}</strong>
          <span>Latest object date</span>
        </article>
      )}
    </div>
  </section>

  <section class="panel operator-panel page-plate">
    <p class="kicker">Operator</p>
    <div class="operator-grid">
      <div>
        <h2>{operator.name}</h2>
        <p class="designation">{operator.designation}</p>
        {operator.handle && <p class="handle">{operator.handle}</p>}
        {operatorExpandedBio && <p class="body-copy operator-bio">{operatorExpandedBio}</p>}
        {operatorLinks.length > 0 && (
          <div class="operator-links-wrap">
            <p class="operator-links-label">Links</p>
            <ul class="operator-links">
              {operatorLinks.map((item) => (
                <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>
        )}
      </div>
      <figure class="operator-media">
        {operator.avatar ? (
          <img src={operator.avatar} alt={`${operator.name} portrait`} loading="lazy" decoding="async" />
        ) : (
          <div class="avatar-fallback" aria-hidden="true">
            <span>{operator.name}</span>
          </div>
        )}
        <figcaption>Primary operator portrait</figcaption>
      </figure>
    </div>
    {operatorNoteParagraphs.length > 0 && (
      <article class="operator-note" aria-labelledby="operator-note-title">
        {operatorNoteTitle && <p class="operator-note-kicker" id="operator-note-title">{operatorNoteTitle}</p>}
        <div class="operator-note-body">
          {operatorNoteParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        {operatorNoteSignature && <p class="operator-note-signoff">— {operatorNoteSignature}</p>}
      </article>
    )}
  </section>

  <section class="panel intent-panel page-plate">
    <p class="kicker">Intent</p>
    <h2>Core operating rule</h2>
    <p class="rule">{coreOperatingRule}</p>
    <blockquote class="orientation-statement orientation-statement--intent">
      <p>The Codex is not a CMS. It is an object archive for human creative work.</p>
    </blockquote>
    <div class="intent-stack">
      <article class="stability-envelope">
        <h3>Stability rule</h3>
        <ul class="rule-list">
          {stabilityRules.map((rule) => (
            <li>{rule}</li>
          ))}
        </ul>
      </article>
      <article class="type-envelope">
        <h3>Object legend</h3>
        <p class="body-copy legend-intro">
          <strong>{typeCounts.length}</strong> active object types. Each one has a clear job in the Codex.
        </p>
        <ul class="type-catalog">
          {typeCounts.map((item) => (
            <li class={`type-definition page-plate ${item.type}`}>
              <div class="type-definition-head">
                <TypeBadge type={item.type} showIcon={true} />
                <span class="type-definition-count">{item.count} objects</span>
              </div>
              <p>{typeDefinitionMap[item.type].description}</p>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="panel fieldmap-panel page-plate">
    <p class="kicker">System field map</p>
    <h2>Schema routes into reading surfaces.</h2>
    <p class="body-copy">
      This diagram shows how object types travel through the archive and where core fields
      hold the contract between operator input and reader-facing output.
    </p>
    <div class="fieldmap-layout">
      <figure class="fieldmap-canvas page-plate" aria-label="Object type field map">
        <svg class="fieldmap-lines" viewBox="0 0 900 520" preserveAspectRatio="none" aria-hidden="true">
          <path d="M22 468 C205 378 318 242 504 250 C665 258 786 162 876 52" />
          <path d="M82 72 C268 122 316 286 488 302 C668 318 770 390 886 472" />
          <path d="M106 452 C234 372 264 186 426 120 C580 56 716 142 834 298" />
          <path d="M312 492 C300 358 362 254 484 210 C598 170 702 242 742 372" />
          <path d="M78 258 H840" />
        </svg>
        <ul class="fieldmap-nodes">
          {orientationMapNodes.map((node) => (
            <li class="fieldmap-node" style={`--x:${node.x}; --y:${node.y};`}>
              <TypeBadge type={node.type} />
              <span>{node.note}</span>
            </li>
          ))}
        </ul>
      </figure>
      <article class="field-contract page-plate">
        <h3>Field contract</h3>
        <div class="field-contract-grid">
          <div class="field-contract-row header">
            <div class="contract-cell">Field</div>
            <div class="contract-cell">Renders</div>
            <div class="contract-cell">Owner</div>
            <div class="contract-cell">Role</div>
          </div>
          {fieldContractRows.map((row) => (
            <div class="field-contract-row">
              <div class="contract-cell name">{row.field}</div>
              <div class="contract-cell">{row.renders}</div>
              <div class="contract-cell">{row.owner}</div>
              <div class="contract-cell">{row.role}</div>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section class="panel constellation-panel page-plate">
    <p class="kicker">Basic constellation</p>
    <h2>Active constellation map</h2>
    <p class="body-copy">
      Constellations are editor-assigned clusters used to preserve legibility,
      improve relation quality, and support retrieval over time.
    </p>
    <div class="constellation-grid">
      {constellationCards.map((item) => (
        <article class={`constellation-card page-plate ${item.tone}`}>
          <h3>{item.name}</h3>
          <p>{item.description}</p>
          <div class="constellation-meta">
            <span>{item.scope}</span>
            <code>{item.count} objects</code>
          </div>
        </article>
      ))}
    </div>
    <p class="capacity">{activeConstellations.length} active of 100 capacity.</p>
  </section>

  <section class="panel path-panel page-plate">
    <p class="kicker">Read path</p>
    <h2>How to move through the archive</h2>
    <ol>
      <li>Start in Feed for newest-first objects and optional pinned emphasis.</li>
      <li>Open object pages for body-first reading, then metadata and relations.</li>
      <li>Use Nexus for intentional sequences and Graph for network-level context.</li>
    </ol>
  </section>
</BaseLayout>

<style>
  .kicker {
    margin: 0 0 0.5rem;
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    font-weight: 400;
  }

  .orientation-hero .page-hero-title {
    max-width: 17ch;
  }

  .orientation-statement {
    margin: 1.35rem 0 0;
    padding: 1rem 0 0.2rem 1rem;
    max-width: 30ch;
    border-left: 2px solid rgba(201, 150, 58, 0.44);
  }

  .orientation-statement p {
    margin: 0;
    color: var(--star);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.9vw, 2.15rem);
    line-height: 1.22;
    letter-spacing: -0.01em;
    font-style: italic;
  }

  .orientation-statement--intent {
    max-width: 34ch;
  }

  .orientation-statement--intent p {
    font-size: clamp(1.38rem, 2.55vw, 2rem);
  }

  .hero-stats {
    margin-top: 2.8rem;
    display: grid;
    gap: 1.35rem;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .hero-stats article {
    --plate-border: rgba(255, 255, 255, 0.14);
    --plate-shadow: 0 18px 40px rgba(0, 0, 0, 0.16);
    --plate-surface: linear-gradient(180deg, rgba(27, 20, 15, 0.88), rgba(14, 11, 9, 0.92));
    --plate-tint: rgba(201, 150, 58, 0.08);
    --plate-tint-secondary: rgba(196, 98, 58, 0.05);
    padding: 1.3rem 1.35rem 1.24rem;
  }

  .hero-stats strong {
    display: block;
    color: var(--star);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.25;
  }

  .hero-stats span {
    display: block;
    margin-top: 0.35rem;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
  }

  .panel {
    --plate-border: rgba(255, 255, 255, 0.12);
    --plate-shadow: 0 24px 56px rgba(0, 0, 0, 0.18);
    --plate-surface: linear-gradient(180deg, rgba(20, 16, 13, 0.9), rgba(11, 10, 9, 0.94));
    --plate-tint: rgba(196, 98, 58, 0.08);
    --plate-tint-secondary: rgba(201, 150, 58, 0.05);
    margin-top: clamp(3.4rem, 6vw, 5rem);
    padding: 2.9rem 3.1rem 3.2rem;
  }

  .panel h2 {
    margin: 0;
    color: var(--star);
    font-size: clamp(1.48rem, 2.8vw, 2.2rem);
    line-height: 1.22;
  }

  .body-copy,
  .rule {
    margin: 1.15rem 0 0;
    color: var(--text-body);
    font-size: 1.05rem;
    line-height: 1.82;
  }

  .intent-panel .rule {
    max-width: 46ch;
  }

  .operator-grid {
    display: grid;
    gap: 2.1rem;
    grid-template-columns: minmax(0, 1fr) clamp(164px, 19vw, 228px);
    align-items: start;
  }

  .operator-media {
    margin: 0;
    display: grid;
    gap: 0.48rem;
    justify-items: end;
    align-self: start;
  }

  .operator-grid img,
  .avatar-fallback {
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    object-fit: cover;
    background: rgba(0, 0, 0, 0.34);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
  }

  .avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(150deg, rgba(196, 98, 58, 0.22), rgba(26, 34, 45, 0.44));
  }

  .avatar-fallback span {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
  }

  .operator-media figcaption {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    text-align: right;
  }

  .designation {
    margin: 0.6rem 0 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
  }

  .handle {
    margin: 0.55rem 0 0;
    color: var(--gold);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
  }

  .operator-bio {
    margin-top: 1.1rem;
    max-width: 56ch;
  }

  .operator-links-wrap {
    margin-top: 1.25rem;
  }

  .operator-links-label {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .operator-links {
    list-style: none;
    margin: 0.38rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.66rem;
  }

  .operator-links a {
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 2px;
    padding: 0.23rem 0.42rem;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    line-height: 1.3;
  }

  .operator-links a:hover {
    border-color: rgba(201, 150, 58, 0.55);
    color: var(--star);
  }

  .operator-note {
    margin-top: clamp(2.8rem, 5vw, 4rem);
    padding-top: clamp(2rem, 3.7vw, 2.9rem);
    border-top: 1px solid rgba(201, 150, 58, 0.18);
    max-width: 76ch;
  }

  .operator-note-kicker {
    margin: 0;
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    font-weight: 400;
  }

  .operator-note-body {
    margin-top: 1.25rem;
    display: grid;
    gap: 1.2rem;
  }

  .operator-note-body p {
    margin: 0;
    color: var(--text-body);
    font-size: clamp(1.04rem, 0.96rem + 0.16vw, 1.14rem);
    line-height: 1.92;
    max-width: 68ch;
  }

  .operator-note-signoff {
    margin: 1.9rem 0 0;
    color: var(--star);
    font-family: var(--font-display);
    font-size: clamp(1.12rem, 1rem + 0.22vw, 1.26rem);
    font-style: italic;
    line-height: 1.35;
  }

  .intent-stack {
    margin-top: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .intent-stack article {
    border: 0;
    border-radius: 0;
    padding: 0;
    background: transparent;
  }

  .intent-stack h3 {
    margin: 0;
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    font-weight: 400;
  }

  .rule-list {
    margin: 0.78rem 0 0;
    padding-left: 1.1rem;
    color: var(--text-body);
    font-family: var(--font-ui);
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.03em;
  }

  .stability-envelope {
    max-width: 640px;
    padding: 0 0 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .type-envelope {
    padding-top: 0.2rem;
  }

  .legend-intro {
    margin-top: 0.72rem;
    max-width: 62ch;
  }

  .type-catalog {
    margin: 1.7rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem 1.65rem;
    max-width: 1120px;
  }

  .type-definition {
    --plate-border: rgba(255, 255, 255, 0.1);
    --plate-shadow: 0 16px 34px rgba(0, 0, 0, 0.14);
    --plate-surface: linear-gradient(180deg, rgba(22, 17, 14, 0.9), rgba(10, 9, 8, 0.92));
    --plate-tint: rgba(196, 98, 58, 0.08);
    --plate-tint-secondary: rgba(201, 150, 58, 0.05);
    position: relative;
    min-width: 0;
    width: 100%;
    max-width: none;
    min-height: 100%;
    padding: 1.45rem 1.4rem 1.52rem;
  }

  .type-definition-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.28rem;
  }

  .type-definition-head :global(.type-badge) {
    flex-shrink: 0;
  }

  .type-definition-head :global(.type-badge.has-icon) {
    gap: 0.56rem;
    padding: 0.34rem 0.76rem 0.32rem 0.68rem;
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 0 0 1px rgba(196, 98, 58, 0.06);
  }

  .type-definition-head :global(.type-badge.has-icon .type-badge-icon) {
    width: 1.08rem;
    height: 1.08rem;
    opacity: 0.72;
  }

  .type-definition-head :global(.type-badge.has-icon svg) {
    width: 0.98rem;
    height: 0.98rem;
  }

  .type-definition p {
    margin: 0;
    max-width: 16ch;
    color: var(--bone);
    font-size: clamp(1.08rem, 1.4vw, 1.16rem);
    line-height: 1.56;
  }

  .type-definition-count {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    line-height: 1.3;
    text-transform: none;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.12rem;
  }

  .constellation-meta code {
    padding: 2px 7px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 11px;
    line-height: 1.4;
  }

  .fieldmap-layout {
    margin-top: 2.2rem;
    display: grid;
    gap: 2.35rem;
    grid-template-columns: minmax(0, 1.16fr) minmax(0, 0.9fr);
    align-items: start;
  }

  .fieldmap-canvas {
    --plate-border: rgba(255, 255, 255, 0.14);
    --plate-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
    --plate-surface: linear-gradient(180deg, rgba(17, 14, 12, 0.94), rgba(10, 9, 8, 0.98));
    --plate-tint: rgba(196, 98, 58, 0.1);
    --plate-tint-secondary: rgba(78, 107, 150, 0.08);
    margin: 0;
    position: relative;
    min-height: 360px;
    overflow: hidden;
  }

  .fieldmap-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .fieldmap-lines path {
    fill: none;
    stroke: rgba(214, 145, 92, 0.2);
    stroke-width: 2.1;
    stroke-linecap: round;
  }

  .fieldmap-nodes {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
  }

  .fieldmap-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
    display: grid;
    justify-items: center;
    gap: 0.28rem;
    text-align: center;
  }

  .fieldmap-node span {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
