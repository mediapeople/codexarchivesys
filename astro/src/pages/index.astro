---
import BaseLayout from '../layouts/BaseLayout.astro';
import ObjectCard from '../components/ObjectCard.astro';
import { COLLECTIONS, getAllEntries, getTypeLabel } from '../lib/archive';

const entries = await getAllEntries();
const searchParams = Astro.url.searchParams;

const typeParam = searchParams.get('type');
const themeParam = searchParams.get('theme');
const queryParam = (searchParams.get('q') || '').trim();
const normalizedQuery = queryParam.toLowerCase();

const selectedType = COLLECTIONS.includes(typeParam as (typeof COLLECTIONS)[number])
  ? typeParam
  : null;

const themeMap = new Map<string, number>();
for (const entry of entries) {
  for (const theme of entry.data.themes) {
    themeMap.set(theme, (themeMap.get(theme) || 0) + 1);
  }
}
const sortedThemes = [...themeMap.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const selectedTheme = themeParam && themeMap.has(themeParam) ? themeParam : null;

function matchesQuery(entry: (typeof entries)[number]) {
  if (!normalizedQuery) {
    return true;
  }
  const haystack = [
    entry.data.title,
    entry.data.excerpt || '',
    ...entry.data.themes,
    ...entry.data.constellations,
  ]
    .join(' ')
    .toLowerCase();
  return haystack.includes(normalizedQuery);
}

const filteredEntries = entries.filter((entry) => {
  if (selectedType && entry.collection !== selectedType) {
    return false;
  }
  if (selectedTheme && !entry.data.themes.includes(selectedTheme)) {
    return false;
  }
  if (!matchesQuery(entry)) {
    return false;
  }
  return true;
});

const typeCounts = COLLECTIONS
  .map((type) => ({
    type,
    count: entries.filter((entry) => entry.collection === type).length,
  }))
  .filter((item) => item.count > 0);

const constellationSet = new Set(
  entries.flatMap((entry) => entry.data.constellations)
);

function buildHref(nextType: string | null, nextTheme: string | null, nextQuery: string) {
  const params = new URLSearchParams();
  if (nextType) {
    params.set('type', nextType);
  }
  if (nextTheme) {
    params.set('theme', nextTheme);
  }
  if (nextQuery) {
    params.set('q', nextQuery);
  }
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
}
---

<BaseLayout title="Codex Archive">
  <section class="hero">
    <p class="eyebrow">Codex Archive System</p>
    <h1>Object-first archive feed</h1>
    <p class="intro">
      Scrolls, artifacts, field logs, codex documents, fragments, and nexus issues
      live as independent objects. Discovery emerges from shared themes,
      constellations, and explicit relations.
    </p>
  </section>

  <section class="stats">
    <article>
      <strong>{entries.length}</strong>
      <span>Objects</span>
    </article>
    <article>
      <strong>{typeCounts.length}</strong>
      <span>Types in use</span>
    </article>
    <article>
      <strong>{constellationSet.size}</strong>
      <span>Constellations</span>
    </article>
  </section>

  <section class="type-grid">
    {typeCounts.map((item) => (
      <article class="type-box">
        <p>{getTypeLabel(item.type)}</p>
        <strong>{item.count}</strong>
      </article>
    ))}
  </section>

  <section class="controls">
    <form action="/" method="GET" class="search">
      {selectedType && <input type="hidden" name="type" value={selectedType} />}
      {selectedTheme && <input type="hidden" name="theme" value={selectedTheme} />}
      <input
        type="search"
        name="q"
        value={queryParam}
        placeholder="Search title, excerpt, themes..."
      />
      <button type="submit">Search</button>
      {(selectedType || selectedTheme || queryParam) && (
        <a href="/">Clear</a>
      )}
    </form>

    <div class="chip-row">
      <a class={selectedType ? 'chip' : 'chip on'} href={buildHref(null, selectedTheme, queryParam)}>
        All Types
      </a>
      {typeCounts.map((item) => (
        <a
          class={selectedType === item.type ? 'chip on' : 'chip'}
          href={buildHref(item.type, selectedTheme, queryParam)}
        >
          {getTypeLabel(item.type)} ({item.count})
        </a>
      ))}
    </div>

    <div class="chip-row themes">
      <a class={selectedTheme ? 'chip' : 'chip on'} href={buildHref(selectedType, null, queryParam)}>
        All Themes
      </a>
      {sortedThemes.slice(0, 16).map(([theme, count]) => (
        <a
          class={selectedTheme === theme ? 'chip on' : 'chip'}
          href={buildHref(selectedType, theme, queryParam)}
        >
          {theme} ({count})
        </a>
      ))}
    </div>

    <p class="result-count">
      Showing {filteredEntries.length} of {entries.length} objects
    </p>
  </section>

  <section class="feed">
    {filteredEntries.length === 0 ? (
      <article class="empty-state">
        <h2>No matches</h2>
        <p>Try clearing one filter or using a broader search term.</p>
      </article>
    ) : (
      filteredEntries.map((entry) => (
        <ObjectCard entry={entry} />
      ))
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 1.1rem;
    padding: 1.2rem 1.1rem;
    border: 1px solid rgba(175, 163, 121, 0.28);
    border-radius: 18px;
    background:
      radial-gradient(circle at 85% 22%, rgba(237, 199, 111, 0.16), transparent 40%),
      linear-gradient(160deg, rgba(19, 21, 30, 0.86), rgba(17, 20, 27, 0.86));
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 600;
  }

  h1 {
    margin: 0.35rem 0 0.45rem;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    line-height: 1.08;
  }

  .intro {
    margin: 0;
    max-width: 72ch;
    color: var(--text-body);
    line-height: 1.45;
  }

  .stats {
    margin: 0 0 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .stats article {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 0.75rem;
    background: rgba(15, 18, 26, 0.48);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stats strong {
    color: var(--text-strong);
    font-size: 1.35rem;
    line-height: 1;
  }

  .stats span {
    color: var(--text-dim);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .type-grid {
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.55rem;
  }

  .type-box {
    border: 1px dashed rgba(194, 184, 151, 0.3);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
    background: rgba(21, 24, 33, 0.44);
  }

  .type-box p {
    margin: 0;
    font-size: 0.76rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .type-box strong {
    color: var(--text-strong);
    font-size: 1.2rem;
  }

  .feed {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.8rem;
  }

  .controls {
    margin: 0 0 1rem;
    border: 1px solid rgba(177, 166, 132, 0.24);
    border-radius: 14px;
    padding: 0.75rem;
    background: rgba(16, 19, 28, 0.62);
  }

  .search {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }

  .search input {
    flex: 1 1 260px;
    min-width: 0;
    border: 1px solid rgba(177, 166, 132, 0.35);
    border-radius: 10px;
    padding: 0.5rem 0.65rem;
    background: rgba(13, 16, 23, 0.72);
    color: var(--text-strong);
  }

  .search button,
  .search a {
    border: 1px solid rgba(177, 166, 132, 0.45);
    border-radius: 10px;
    padding: 0.46rem 0.72rem;
    background: rgba(31, 36, 49, 0.8);
    color: var(--text-body);
    text-decoration: none;
    font-size: 0.86rem;
  }

  .search button:hover,
  .search a:hover {
    border-color: rgba(236, 205, 119, 0.8);
    color: var(--text-strong);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.45rem;
  }

  .chip {
    border: 1px solid rgba(143, 153, 176, 0.42);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    color: #b7c0d7;
    text-decoration: none;
    font-size: 0.75rem;
  }

  .chip.on {
    border-color: rgba(236, 205, 119, 0.85);
    color: #f1d798;
    background: rgba(60, 49, 18, 0.45);
  }

  .themes .chip {
    border-color: rgba(112, 210, 167, 0.45);
    color: #9ad8be;
  }

  .themes .chip.on {
    border-color: rgba(112, 210, 167, 0.95);
    background: rgba(27, 58, 49, 0.45);
  }

  .result-count {
    margin: 0.45rem 0 0;
    color: var(--text-dim);
    font-size: 0.82rem;
  }

  .empty-state {
    border: 1px dashed rgba(179, 169, 137, 0.38);
    border-radius: 14px;
    padding: 1rem;
    background: rgba(19, 23, 32, 0.72);
  }

  .empty-state h2 {
    margin: 0 0 0.3rem;
    color: var(--text-strong);
    font-size: 1.08rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--text-body);
  }

  @media (max-width: 700px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }
</style>
