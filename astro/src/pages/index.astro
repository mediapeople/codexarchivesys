---
import BaseLayout from '../layouts/BaseLayout.astro';
import ObjectCard from '../components/ObjectCard.astro';
import { COLLECTIONS, getAllEntries, getTypeLabel } from '../lib/archive';
import { getMediaItems, pickPrimaryMedia } from '../lib/media';

const entries = await getAllEntries();

const typeCounts = COLLECTIONS
  .map((type) => ({
    type,
    count: entries.filter((entry) => entry.collection === type).length,
  }))
  .filter((item) => item.count > 0);

const constellationSet = new Set(
  entries.flatMap((entry) => entry.data.constellations)
);

const entriesWithMedia = entries
  .map((entry) => {
    const media = getMediaItems(entry);
    return {
      entry,
      mediaCount: media.length,
      primaryMedia: pickPrimaryMedia(media),
    };
  })
  .filter((item) => item.mediaCount > 0)
  .slice(0, 4);
---

<BaseLayout title="Codex Archive">
  <section class="hero">
    <p class="eyebrow">Codex Archive System</p>
    <h1>Object-first archive feed</h1>
    <p class="intro">
      Scrolls, artifacts, field logs, codex documents, fragments, and nexus issues
      live as independent objects. Discovery emerges from shared themes,
      constellations, and explicit relations.
    </p>
  </section>

  <section class="stats">
    <article>
      <strong>{entries.length}</strong>
      <span>Objects</span>
    </article>
    <article>
      <strong>{typeCounts.length}</strong>
      <span>Types in use</span>
    </article>
    <article>
      <strong>{constellationSet.size}</strong>
      <span>Constellations</span>
    </article>
  </section>

  <section class="type-grid">
    {typeCounts.map((item) => (
      <article class="type-box">
        <p>{getTypeLabel(item.type)}</p>
        <strong>{item.count}</strong>
      </article>
    ))}
  </section>

  {entriesWithMedia.length > 0 && (
    <section class="media-strip">
      <header>
        <p>Visual Ledger</p>
        <span>{entriesWithMedia.length} objects currently carrying media evidence</span>
      </header>
      <div class="media-grid">
        {entriesWithMedia.map((item) => (
          <a href={`/objects/${item.entry.data.id}`} class="media-tile">
            {item.primaryMedia?.kind === 'image' ? (
              <img
                src={item.primaryMedia.src}
                alt={item.primaryMedia.alt || `${item.entry.data.title} media`}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="media-fallback">
                {item.primaryMedia ? item.primaryMedia.kind.toUpperCase() : 'MEDIA'}
              </div>
            )}
            <div class="tile-meta">
              <strong>{item.entry.data.title}</strong>
              <span>{item.mediaCount} media items</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="feed">
    {entries.map((entry) => (
      <ObjectCard entry={entry} />
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 1.1rem;
    padding: 1.2rem 1.1rem;
    border: 1px solid rgba(175, 163, 121, 0.28);
    border-radius: 18px;
    background:
      radial-gradient(circle at 85% 22%, rgba(237, 199, 111, 0.16), transparent 40%),
      linear-gradient(160deg, rgba(19, 21, 30, 0.86), rgba(17, 20, 27, 0.86));
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 600;
  }

  h1 {
    margin: 0.35rem 0 0.45rem;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    line-height: 1.08;
  }

  .intro {
    margin: 0;
    max-width: 72ch;
    color: var(--text-body);
    line-height: 1.45;
  }

  .stats {
    margin: 0 0 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .stats article {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 0.75rem;
    background: rgba(15, 18, 26, 0.48);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stats strong {
    color: var(--text-strong);
    font-size: 1.35rem;
    line-height: 1;
  }

  .stats span {
    color: var(--text-dim);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
  }

  .type-grid {
    margin: 0 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.55rem;
  }

  .type-box {
    border: 1px dashed rgba(194, 184, 151, 0.3);
    border-radius: 12px;
    padding: 0.65rem 0.75rem;
    background: rgba(21, 24, 33, 0.44);
  }

  .type-box p {
    margin: 0;
    font-size: 0.76rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .type-box strong {
    color: var(--text-strong);
    font-size: 1.2rem;
  }

  .feed {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.8rem;
  }

  .media-strip {
    margin: 0 0 1rem;
    border: 1px solid rgba(167, 156, 125, 0.34);
    border-radius: 16px;
    background: rgba(17, 21, 30, 0.74);
    padding: 0.75rem;
  }

  .media-strip header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem;
    margin-bottom: 0.55rem;
  }

  .media-strip p {
    margin: 0;
    color: #7ecfb6;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .media-strip span {
    color: var(--text-dim);
    font-size: 0.78rem;
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.5rem;
  }

  .media-tile {
    text-decoration: none;
    border: 1px solid rgba(161, 151, 125, 0.32);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(11, 15, 24, 0.74);
  }

  .media-tile img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .media-fallback {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: grid;
    place-items: center;
    color: var(--text-dim);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    background: linear-gradient(160deg, rgba(85, 146, 126, 0.28), rgba(56, 83, 107, 0.2));
  }

  .tile-meta {
    padding: 0.45rem 0.5rem 0.52rem;
    display: grid;
    gap: 0.2rem;
  }

  .tile-meta strong {
    color: var(--text-strong);
    font-size: 0.83rem;
    line-height: 1.25;
    font-weight: 600;
  }

  .tile-meta span {
    color: var(--text-dim);
    font-size: 0.73rem;
  }

  @media (max-width: 700px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }
</style>
