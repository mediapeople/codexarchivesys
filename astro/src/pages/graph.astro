---
import fs from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDisplayTitle } from '../lib/headline';

type GraphNode = {
  id: string;
  title: string;
  type: string;
};

type GraphEdge = {
  source: string;
  target: string;
  weight: number;
  reasons: string[];
};

type GraphPayload = {
  generatedAt: string;
  nodeCount: number;
  edgeCount: number;
  nodes: GraphNode[];
  edges: GraphEdge[];
};

const defaultGraph: GraphPayload = {
  generatedAt: '',
  nodeCount: 0,
  edgeCount: 0,
  nodes: [],
  edges: [],
};

const graphPath = new URL('../../public/graph.json', import.meta.url);

let graph = defaultGraph;
let loadError = '';

try {
  graph = JSON.parse(fs.readFileSync(graphPath, 'utf8')) as GraphPayload;
} catch (error) {
  loadError = error instanceof Error ? error.message : 'Unable to load graph.json';
}

const topEdges = [...graph.edges].sort((a, b) => b.weight - a.weight).slice(0, 12);

const topNodes = [...graph.nodes]
  .map((node) => {
    const totalWeight = graph.edges
      .filter((edge) => edge.source === node.id || edge.target === node.id)
      .reduce((sum, edge) => sum + edge.weight, 0);
    return { ...node, totalWeight };
  })
  .sort((a, b) => b.totalWeight - a.totalWeight)
  .slice(0, 12);
---

<BaseLayout title="Codex Graph">
  <section class="graph-meta">
    <p class="label">Graph export</p>
    <h1>Archive relation snapshot.</h1>
    <p class="intro">
      Read the structure layer directly: how objects connect, where weight accumulates, and what links carry the most signal.
    </p>
    <div class="meta-row">
      <a class="source-link" href="/graph.json" target="_blank" rel="noreferrer">Open source JSON</a>
      {graph.generatedAt && (
        <span class="generated">Generated {new Date(graph.generatedAt).toLocaleString('en-US')}</span>
      )}
    </div>
  </section>

  {loadError ? (
    <section class="error">
      <h2>Graph Not Loaded</h2>
      <p>{loadError}</p>
      <p>Run <code>node scripts/generate-graph-json.mjs objects astro/public/graph.json</code>.</p>
    </section>
  ) : (
    <>
      <section class="stats">
        <article><strong>{graph.nodeCount}</strong><span>Nodes</span></article>
        <article><strong>{graph.edgeCount}</strong><span>Edges</span></article>
        <article><strong>{topEdges[0]?.weight ?? 0}</strong><span>Strongest Link</span></article>
      </section>

      <section class="grid">
        <article>
          <h2>Top Connected Objects</h2>
          <ul>
            {topNodes.map((node) => (
              <li>
                <a href={`/objects/${node.id}`}>{formatDisplayTitle(node.title)}</a>
                <span>{node.type} · {node.totalWeight}</span>
              </li>
            ))}
          </ul>
        </article>

        <article>
          <h2>Top Edges</h2>
          <ul>
            {topEdges.map((edge) => (
              <li>
                <a href={`/objects/${edge.source}`}>{edge.source}</a>
                <span>↔</span>
                <a href={`/objects/${edge.target}`}>{edge.target}</a>
                <code>{edge.weight}</code>
              </li>
            ))}
          </ul>
        </article>
      </section>
    </>
  )}
</BaseLayout>

<style>
  .graph-meta {
    padding: 6rem 0 3.2rem;
    background: transparent;
    margin-bottom: 2.4rem;
  }

  .label {
    margin: 0 0 0.45rem;
    color: var(--accent);
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: var(--ls-label);
    font-size: 12px;
    font-weight: 400;
  }

  .graph-meta h1 {
    margin: 0;
    max-width: 20ch;
    color: var(--star);
    font-size: clamp(2rem, 4.2vw, 3.1rem);
    line-height: 1.08;
  }

  .intro {
    margin: 1rem 0 0;
    color: var(--text-body);
    font-size: 1.08rem;
    line-height: 1.78;
    max-width: 58ch;
  }

  .meta-row {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.9rem;
    align-items: center;
  }

  .source-link {
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    padding: 4px 8px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-ui-wide);
  }

  .source-link:hover {
    border-color: rgba(196, 98, 58, 0.55);
    color: var(--star);
  }

  .generated {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.8rem;
    margin-bottom: 5.2rem;
  }

  .stats article {
    padding: 0;
    background: transparent;
  }

  .stats strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 4.1vw, 3.45rem);
    color: var(--star);
    line-height: 1;
    letter-spacing: var(--ls-display);
  }

  .stats span {
    color: rgba(232, 226, 212, 0.7);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--ls-ui-wide);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 4rem;
  }

  .grid article {
    padding: 0;
    background: transparent;
  }

  .grid h2 {
    margin: 0 0 2rem;
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  .grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.9rem;
  }

  .grid li {
    display: flex;
    gap: 0.45rem;
    align-items: baseline;
    flex-wrap: wrap;
    font-size: 1.2rem;
    line-height: 1.42;
  }

  .grid a {
    color: var(--star);
    text-decoration: none;
    font-style: italic;
    font-weight: 700;
  }

  .grid a:hover {
    color: var(--gold);
  }

  .grid span {
    color: rgba(232, 226, 212, 0.68);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .grid code {
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    padding: 1px 6px;
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 11px;
  }

  .error {
    border: 1px solid rgba(224, 96, 48, 0.5);
    border-radius: 2px;
    padding: 1.8rem;
    background: rgba(58, 22, 12, 0.5);
  }

  .error h2 {
    margin: 0 0 0.4rem;
    color: var(--ember);
    font-size: 16px;
    font-style: italic;
    font-weight: 500;
  }

  .error p {
    margin: 0 0 0.45rem;
    color: var(--bone);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  @media (max-width: 700px) {
    .stats {
      grid-template-columns: 1fr;
    }

    .graph-meta {
      padding-top: 3.8rem;
      padding-bottom: 2.2rem;
    }
  }
</style>
