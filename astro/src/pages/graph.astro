  .graph-summary-strip {
    --plate-border: rgba(255, 255, 255, 0.12);
    --plate-shadow: 0 24px 60px rgba(0, 0, 0, 0.24);
    --plate-surface: linear-gradient(180deg, rgba(34, 23, 17, 0.93), rgba(16, 12, 10, 0.97));
    --plate-tint: rgba(212, 138, 83, 0.08);
    --plate-tint-secondary: rgba(120, 160, 168, 0.06);
  }

  .graph-kpi {
    padding: 1.3rem 1.35rem 1.24rem;
    min-height: 108px;
    display: grid;
    align-content: end;
    gap: 0.35rem;
  }

  .graph-kpi-value {
    color: var(--star);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.3vw, 1.95rem);
    line-height: 1.04;
    text-wrap: balance;
  }

  .graph-kpi-label {
    color: rgba(232, 226, 212, 0.7);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-explorer {
    display: grid;
    grid-template-columns: minmax(0, 1.16fr) minmax(320px, 0.9fr);
    gap: var(--graph-column-gap);
    align-items: start;
  }

  .graph-panel {
    padding: var(--graph-block-space) var(--graph-inline-space);
  }

  .graph-map-surface {
    min-width: 0;
    display: grid;
    gap: 1.15rem;
    overflow: visible;
    padding: var(--graph-block-space) var(--graph-inline-space);
  }

  .graph-summary-strip {
    --plate-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
    padding: calc(var(--graph-block-space) - 0.2rem) var(--graph-inline-space) var(--graph-block-space);
  }

  .graph-filter-tray {
    display: grid;
    gap: 0.85rem;
    padding-bottom: 1.15rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .graph-filter-bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
  }

  .graph-filter-copy {
    display: grid;
    gap: 0.2rem;
  }

  .graph-filter-summary {
    margin: 0;
    color: rgba(232, 226, 212, 0.7);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    line-height: 1.5;
    text-transform: uppercase;
  }

  .graph-filter-toggle {
    appearance: none;
    -webkit-appearance: none;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    background: rgba(12, 9, 7, 0.56);
    color: rgba(232, 226, 212, 0.82);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    cursor: pointer;
    padding: 0.6rem 0.8rem;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
  }

  .graph-filter-toggle:hover,
  .graph-filter-tray[data-open='true'] .graph-filter-toggle {
    border-color: rgba(212, 138, 83, 0.46);
    color: var(--star);
    background: rgba(212, 138, 83, 0.08);
  }

  .graph-filter-stack {
    padding-top: 0.15rem;
  }

  .graph-filter-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 0.9rem 1rem;
    align-items: start;
  }

  .graph-panel--inspector {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 5.5rem;
  }

  .graph-selected-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
  }

  .graph-selected-heading {
    min-width: 0;
    display: grid;
    gap: 0.1rem;
  }

  .graph-selected-open {
    flex: 0 0 auto;
    color: var(--star);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-open:hover {
    color: var(--gold);
  }

  .graph-panel-section {
    display: grid;
    gap: 0.7rem;
  }

  .graph-panel-section--modes {
    gap: 0.85rem;
  }

  .graph-panel-section--types {
    grid-column: 1 / -1;
  }

  .graph-filter-compact-group {
    display: grid;
    gap: 0.55rem;
  }

  .graph-panel-header,
  .graph-selected-links-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .graph-search {
    display: grid;
    gap: 0.45rem;
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    color: rgba(232, 226, 212, 0.72);
  }

  .graph-search input,
  .graph-threshold-slider,
  .graph-toggle,
  .graph-spotlight,
  .graph-type-pill,
  .graph-type-reset {
    appearance: none;
    -webkit-appearance: none;
  }

  .graph-search input {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    padding: 0.78rem 0.9rem;
    background: rgba(12, 9, 7, 0.62);
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 12.5px;
    letter-spacing: 0.02em;
  }

  .graph-search input::placeholder {
    color: rgba(232, 226, 212, 0.38);
  }

  .graph-threshold-value {
    color: var(--star);
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
  }

  .graph-threshold-slider {
    width: 100%;
    height: 6px;
    border-radius: 0;
    background: linear-gradient(90deg, rgba(212, 138, 83, 0.72), rgba(120, 160, 168, 0.42));
    outline: none;
  }

  .graph-threshold-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.82);
    background: var(--star);
    box-shadow: 0 0 0 4px rgba(232, 226, 212, 0.08);
    cursor: pointer;
  }

  .graph-threshold-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.82);
    background: var(--star);
    box-shadow: 0 0 0 4px rgba(232, 226, 212, 0.08);
    cursor: pointer;
  }

  .graph-panel-note {
    margin: 0;
    color: rgba(232, 226, 212, 0.62);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .graph-layout-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .graph-toggle,
  .graph-spotlight,
  .graph-type-pill,
  .graph-type-reset {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    background: rgba(12, 9, 7, 0.56);
    color: rgba(232, 226, 212, 0.8);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .graph-toggle,
  .graph-spotlight {
    padding: 0.85rem 0.9rem;
  }

  .graph-toggle:hover,
  .graph-spotlight:hover,
  .graph-type-pill:hover,
  .graph-type-reset:hover,
  .graph-toggle.is-active,
  .graph-spotlight.is-active,
  .graph-type-pill.is-active,
  .graph-type-reset.is-active {
    border-color: rgba(212, 138, 83, 0.46);
    color: var(--star);
    transform: translateY(-1px);
  }

  .graph-toggle.is-active,
  .graph-spotlight.is-active {
    background: linear-gradient(180deg, rgba(212, 138, 83, 0.24), rgba(212, 138, 83, 0.11));
  }

  .graph-panel-header .graph-type-reset {
    padding: 0.45rem 0.7rem;
  }

  .graph-type-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .graph-type-pill {
    display: inline-grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    gap: 0.55rem;
    padding: 0.58rem 0.75rem;
    text-align: left;
  }

  .graph-type-pill strong {
    color: var(--bone);
    font-size: 12px;
  }

  .graph-type-pill.is-active {
    background: linear-gradient(180deg, var(--type-glow), rgba(255, 255, 255, 0.03));
  }

  .graph-type-swatch {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--type-color);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--type-color) 24%, transparent);
  }

  .graph-stage-rail {
    min-width: 0;
    display: grid;
    gap: 0.9rem;
    padding: 0;
  }

  .graph-stage-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
  }

  .graph-stage-head h2,
  .graph-panel--inspector h2,
  .graph-summary-head h3 {
    margin: 0;
  }

  .graph-stage-head h2 {
    font-size: clamp(1.55rem, 2.4vw, 2.15rem);
  }

  .graph-stage-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    justify-content: flex-end;
  }

  .graph-stage-stats span {
    color: rgba(232, 226, 212, 0.72);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-stage-stats strong {
    color: var(--star);
    margin-right: 0.35rem;
  }

  .graph-stage-frame {
    --plate-border: rgba(255, 255, 255, 0.12);
    --plate-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
    --plate-surface: linear-gradient(180deg, rgba(24, 17, 13, 0.97), rgba(10, 8, 7, 0.99));
    --plate-tint: rgba(212, 138, 83, 0.1);
    --plate-tint-secondary: rgba(120, 160, 168, 0.08);
    padding: 1rem;
  }

  .graph-stage-frame[data-layout='chronicle'] {
    --plate-surface: linear-gradient(180deg, rgba(16, 17, 20, 0.96), rgba(9, 10, 13, 0.99));
    --plate-tint: rgba(120, 160, 168, 0.1);
    --plate-tint-secondary: rgba(212, 138, 83, 0.08);
  }

  .graph-canvas {
    display: block;
    width: 100%;
    aspect-ratio: 1120 / 760;
  }

  .graph-stage-note {
    margin: 0;
    max-width: 64ch;
    color: rgba(232, 226, 212, 0.62);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    line-height: 1.55;
    text-transform: uppercase;
  }

  .graph-stage-empty {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%);
    padding: 1rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    background: rgba(9, 8, 7, 0.86);
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.8rem;
    margin-top: 0.1rem;
    align-items: center;
  }

  .graph-selected-type {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    border-radius: 0;
    border: 1px solid color-mix(in srgb, var(--type-color) 48%, rgba(255, 255, 255, 0.14));
    background: color-mix(in srgb, var(--type-color) 16%, rgba(9, 8, 7, 0.56));
    color: var(--bone);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-meta span:last-child {
    color: rgba(232, 226, 212, 0.68);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-summary {
    margin: 0.55rem 0 0;
    color: rgba(232, 226, 212, 0.74);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .graph-selected-hint {
    margin: -0.1rem 0 0;
    color: rgba(232, 226, 212, 0.56);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    line-height: 1.55;
    text-transform: uppercase;
  }

  .graph-selected-metrics {
    margin: 0.85rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(136px, 1fr));
    gap: 0.65rem 1.2rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .graph-selected-metrics div {
    padding: 0.55rem 0 0.7rem;
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .graph-selected-metrics dt {
    margin: 0;
    color: rgba(232, 226, 212, 0.58);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-metrics dd {
    margin: 0.35rem 0 0;
    color: var(--star);
    font-family: var(--font-display);
    font-size: 1.02rem;
    line-height: 1;
  }

  .graph-selected-tag-group {
    display: grid;
    gap: 0.55rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .graph-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.9rem;
  }

  .graph-tag-cloud span {
    padding: 0;
    border-radius: 0;
    border: 0;
    background: transparent;
    color: rgba(232, 226, 212, 0.8);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-tag-cloud .is-empty {
    color: rgba(232, 226, 212, 0.52);
  }

  .graph-selected-links {
    display: grid;
    gap: 0.7rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .graph-selected-links ul,
  .graph-summary-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .graph-selected-links li,
  .graph-summary-list li {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: start;
    padding: 0.78rem 0;
    border-radius: 0;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
  }

  .graph-selected-links li button,
  .graph-summary-list a {
    color: var(--star);
    text-decoration: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .graph-selected-links li button {
    display: grid;
    gap: 0.2rem;
    color: var(--star);
    font-size: 0.94rem;
  }

  .graph-selected-links li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .graph-selected-links li button small {
    color: rgba(232, 226, 212, 0.52);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-selected-links li span,
  .graph-summary-list span,
  .graph-summary-list code {
    color: rgba(232, 226, 212, 0.74);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-secondary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem var(--graph-column-gap);
    padding-top: 0.65rem;
  }

  .graph-summary-strip {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
  }

  .graph-summary-strip--reasons {
    grid-column: 1 / -1;
  }

  .graph-summary-head {
    display: grid;
    gap: 0.15rem;
  }

  .graph-summary-strip .graph-summary-head {
    padding-top: 0;
    border-top: 0;
  }

  .graph-summary-list li a {
    font-style: italic;
    font-weight: 700;
  }

  .graph-summary-list li a:hover,
  .graph-selected-links li button:hover,
  .graph-source-link:hover {
    color: var(--gold);
  }

  .graph-summary-list li span {
    max-width: 16ch;
    text-align: right;
  }

  .graph-summary-list--compact li span {
    color: rgba(232, 226, 212, 0.82);
    text-align: left;
    max-width: none;
  }

  .graph-summary-list--simple {
    gap: 0;
  }

  .graph-summary-list--simple li {
    padding: 0.85rem 0;
    border-radius: 0;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
  }

  .graph-summary-list--simple li:first-child {
    padding-top: 0.25rem;
  }

  .graph-summary-list--simple li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .graph-summary-list--simple li a {
    font-style: normal;
  }

  .graph-summary-list--simple li span {
    max-width: 18ch;
  }

  .graph-summary-list code {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0;
    padding: 0.2rem 0.55rem;
  }

  .graph-reason-strip {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem 1rem;
  }

  .graph-reason-strip li {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: baseline;
    padding: 0.7rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .graph-reason-strip span,
  .graph-reason-strip code {
    color: rgba(232, 226, 212, 0.82);
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
  }

  .graph-reason-strip code {
    color: var(--star);
    border: 0;
    padding: 0;
  }

  .graph-edge-copy {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
  }

  .graph-error {
    padding: 1.5rem;
  }

  .graph-error h2 {
    margin: 0 0 0.45rem;
    color: var(--ember);
    font-size: 1.05rem;
  }

  .graph-error p {
    margin: 0 0 0.45rem;
    color: var(--bone);
    line-height: 1.7;
  }

  .graph-background-layer,
  .graph-edge-layer,
  .graph-node-layer {
    pointer-events: none;
  }

  .graph-node-layer .graph-node {
    pointer-events: auto;
    cursor: pointer;
  }

  .graph-cluster-ring,
  .graph-lane,
  .graph-time-tick,
  .graph-center-halo {
    fill: none;
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .graph-cluster-core {
    stroke: rgba(17, 12, 10, 0.75);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .graph-center-halo {
    stroke: rgba(212, 138, 83, 0.08);
  }

  .graph-cluster-label,
  .graph-node-label,
  .graph-lane-label,
  .graph-time-label {
    fill: rgba(232, 226, 212, 0.82);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    paint-order: stroke;
    stroke: rgba(12, 9, 7, 0.86);
    stroke-width: 3px;
    stroke-linejoin: round;
  }

  .graph-time-label {
    text-anchor: middle;
  }

  .graph-edge {
    fill: none;
    stroke: rgba(232, 226, 212, 0.12);
    vector-effect: non-scaling-stroke;
  }

  .graph-edge.is-selected {
    stroke: rgba(212, 138, 83, 0.7);
  }

  .graph-edge.is-hovered {
    stroke: rgba(120, 160, 168, 0.66);
  }

  .graph-node-halo {
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .graph-node-dot {
    stroke: rgba(12, 9, 7, 0.9);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
    transition: transform 160ms ease;
  }

  .graph-node.is-selected .graph-node-halo,
  .graph-node.is-hovered .graph-node-halo {
    opacity: 1;
  }

  .graph-node.is-selected .graph-node-label {
    fill: var(--star);
  }

  .graph-node:focus-visible .graph-node-dot,
  .graph-node.is-selected .graph-node-dot {
    stroke: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 1100px) {
    .graph-explorer {
      grid-template-columns: minmax(0, 1fr);
    }

    .graph-panel--inspector {
      position: relative;
      top: auto;
    }

    .graph-filter-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1040px) {
    .graph-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .graph-kpi {
      min-height: 96px;
      padding: 1.05rem 1.05rem 1rem;
    }

    .graph-kpi-value--hub {
      font-size: clamp(1rem, 2vw, 1.4rem);
      line-height: 1.08;
