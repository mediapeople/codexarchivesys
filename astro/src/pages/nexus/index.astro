---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import { formatDisplayTitle } from '../../lib/headline';
import { compareByPureTimeline, formatArchiveDate } from '../../lib/timeline';

const issues = (await getCollection('nexus'))
  .filter((entry) => entry.data.status === 'published' && entry.data.visibility === 'public')
  .sort(
    (a, b) => compareByPureTimeline(a, b) || b.data.id.localeCompare(a.data.id)
  );
---

<BaseLayout title="Nexus Issues">
  <section class="stream-meta">
    <p class="label">Nexus stream</p>
    <p class="intro">
      Nexus issues are guided reading sequences built from archive objects.
      They carry editorial ordering and transmission intent.
    </p>
  </section>

  <section class="issues">
    {issues.map((issue) => (
      <article class="issue">
        <a class="hitbox" href={`/nexus/${issue.data.id}`} aria-label={`Open ${issue.data.title}`}></a>
        <div class="copy">
          <header>
            <TypeBadge type="nexus" />
            <span>{formatArchiveDate(issue.data.date)}</span>
          </header>
          <h2>{formatDisplayTitle(issue.data.title)}</h2>
          {issue.data.excerpt && <p class="excerpt">{issue.data.excerpt}</p>}
          {issue.data.themeStatement && <p class="statement">{issue.data.themeStatement}</p>}
          <div class="meta">
            <span>{issue.data.includedObjects.length} sequence items</span>
            {issue.data.releaseType && <span>{issue.data.releaseType}</span>}
          </div>
        </div>
        <aside class="visual is-fallback">
          <div class="visual-fallback">
            <span>Nexus</span>
          </div>
        </aside>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .stream-meta {
    margin: 0 auto 2.8rem;
    padding: 6rem clamp(0.45rem, 0.95vw, 1rem) 3rem;
    background: transparent;
  }

  .label {
    margin: 0 0 0.45rem;
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: var(--ls-label);
    font-weight: 400;
  }

  .intro {
    margin: 0;
    color: var(--text-body);
    line-height: 1.78;
    font-size: 1.15rem;
    max-width: 42ch;
  }

  .issues {
    display: grid;
    padding-inline: clamp(0.45rem, 0.95vw, 1rem);
    gap: 5.2rem;
  }

  .issue {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 38%);
    column-gap: 3.5rem;
    align-items: start;
    padding: 0;
    background: transparent;
    transition: transform 0.12s;
  }

  .issue:hover {
    transform: translateY(-1px);
  }

  .issue header {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.05rem;
  }

  .issue header span {
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
  }

  .issue h2 {
    margin: 0;
    max-width: 15ch;
    color: var(--star);
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    line-height: 1.14;
    font-weight: 600;
    letter-spacing: var(--ls-title);
    text-wrap: balance;
  }

  .excerpt,
  .statement {
    margin: 1.3rem 0 0;
    color: var(--text-body);
    line-height: 1.86;
    font-size: 1.22rem;
    max-width: 38ch;
  }

  .statement {
    color: var(--accent-quote-soft);
    font-size: 1.18rem;
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.004em;
  }

  .meta {
    margin-top: 1.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.55rem;
  }

  .meta span {
    padding: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
  }

  .meta span + span::before {
    content: '·';
    margin-right: 0.5rem;
    color: var(--ghost);
  }

  .visual {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 2px;
    overflow: hidden;
    background: rgba(14, 12, 10, 0.64);
    aspect-ratio: 4 / 3;
    isolation: isolate;
  }

  .visual::before,
  .visual::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .visual::before {
    z-index: 1;
    background:
      linear-gradient(150deg, rgba(196, 98, 58, 0.2), rgba(24, 18, 16, 0.94));
    opacity: 1;
  }

  .visual::after {
    z-index: 2;
    background:
      radial-gradient(
        circle at 50% 50%,
        transparent 0 16%,
        rgba(231, 171, 130, 0.08) 16% 17%,
        transparent 17% 33%,
        rgba(231, 171, 130, 0.06) 33% 34%,
        transparent 34% 100%
      ),
      linear-gradient(0deg, rgba(196, 98, 58, 0.07), transparent 58%);
    opacity: 1;
  }

  .visual-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    position: relative;
    z-index: 3;
    background: transparent;
  }

  .visual-fallback span {
    color: rgba(232, 226, 212, 0.84);
    font-family: var(--font-ui);
    font-size: 0.86rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.35);
  }

  .hitbox {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  @media (max-width: 920px) {
    .issue {
      grid-template-columns: 1fr;
      row-gap: 1.45rem;
    }

    .visual {
      max-width: min(700px, 100%);
    }
  }

  @media (max-width: 700px) {
    .stream-meta {
      padding-top: 3.8rem;
      padding-bottom: 2.2rem;
    }

    .issues {
      gap: 3.6rem;
    }

    .issue {
      row-gap: 1rem;
    }

    .issue h2 {
      max-width: 100%;
      font-size: clamp(1.72rem, 7.8vw, 2.34rem);
      line-height: 1.14;
      text-wrap: pretty;
    }

    .excerpt,
    .statement {
      margin-top: 0.85rem;
      font-size: 1rem;
      line-height: 1.66;
      max-width: 100%;
    }

    .meta {
      margin-top: 1rem;
      gap: 0.22rem 0.44rem;
    }

    .meta span {
      font-size: 10px;
    }

    .visual {
      aspect-ratio: 16 / 10;
    }
  }
</style>
