---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/TypeBadge.astro';

const issues = (await getCollection('nexus')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Nexus Issues">
  <section class="hero">
    <p class="eyebrow">Nexus Stream</p>
    <h1>Curated issue releases</h1>
    <p>
      Nexus issues are guided reading sequences built from archive objects.
      They carry editorial ordering and transmission intent.
    </p>
  </section>

  <section class="issues">
    {issues.map((issue) => (
      <article class="issue">
        <a class="hitbox" href={`/nexus/${issue.data.id}`} aria-label={`Open ${issue.data.title}`}></a>
        <header>
          <TypeBadge type="nexus" />
          <span>{issue.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        </header>
        <h2>{issue.data.title}</h2>
        {issue.data.excerpt && <p class="excerpt">{issue.data.excerpt}</p>}
        {issue.data.themeStatement && <p class="statement">{issue.data.themeStatement}</p>}
        <div class="meta">
          <span>{issue.data.includedObjects.length} sequence items</span>
          {issue.data.releaseType && <span>{issue.data.releaseType}</span>}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 1rem;
    border: 1px solid rgba(177, 166, 132, 0.32);
    border-radius: 18px;
    padding: 1rem;
    background: rgba(17, 20, 29, 0.72);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  h1 {
    margin: 0.35rem 0;
    color: var(--text-strong);
  }

  .hero p {
    margin: 0;
    color: var(--text-body);
    line-height: 1.45;
  }

  .issues {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0.8rem;
  }

  .issue {
    position: relative;
    border: 1px solid rgba(177, 166, 132, 0.24);
    border-radius: 16px;
    padding: 1rem;
    background:
      radial-gradient(circle at top right, rgba(160, 132, 247, 0.12), transparent 48%),
      linear-gradient(150deg, rgba(20, 24, 34, 0.9), rgba(16, 19, 28, 0.9));
  }

  .issue header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
  }

  .issue header span {
    color: var(--text-dim);
    font-size: 0.78rem;
  }

  .issue h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1.16rem;
  }

  .excerpt,
  .statement {
    margin: 0.65rem 0 0;
    color: var(--text-body);
    line-height: 1.45;
  }

  .statement {
    color: #cec5a9;
    font-size: 0.92rem;
  }

  .meta {
    margin-top: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .meta span {
    border: 1px solid rgba(177, 166, 132, 0.35);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    color: var(--text-dim);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hitbox {
    position: absolute;
    inset: 0;
    z-index: 2;
  }
</style>

