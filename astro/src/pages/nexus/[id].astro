---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import { getAllEntries } from '../../lib/archive';
import { formatDisplayTitle } from '../../lib/headline';
import { compareByPureTimeline, formatArchiveLongDate } from '../../lib/timeline';

export async function getStaticPaths() {
  const nexusEntries = await getCollection('nexus');
  return nexusEntries.map((entry) => ({
    params: { id: entry.data.id },
  }));
}

const nexusEntries = (await getCollection('nexus')).sort(
  (a, b) => compareByPureTimeline(a, b) || b.data.id.localeCompare(a.data.id)
);

const issue = nexusEntries.find((entry) => entry.data.id === Astro.params.id);
if (!issue) {
  throw new Error(`Missing nexus issue for id: ${Astro.params.id}`);
}

const { Content } = await issue.render();

const allEntries = await getAllEntries();
const byId = new Map(allEntries.map((entry) => [entry.data.id, entry]));
const sequence = issue.data.includedObjects
  .map((item, index) => ({
    index: index + 1,
    role: item.role,
    entry: byId.get(item.ref) || null,
    ref: item.ref,
  }))
  .filter((item) => Boolean(item.entry));

const issueIndex = nexusEntries.findIndex((entry) => entry.data.id === issue.data.id);
const newerIssue = issueIndex > 0 ? nexusEntries[issueIndex - 1] : null;
const olderIssue = issueIndex < nexusEntries.length - 1 ? nexusEntries[issueIndex + 1] : null;
const displayIssueTitle = formatDisplayTitle(issue.data.title);
const nexusContextQuery = `?from=nexus&nexus=${encodeURIComponent(issue.data.id)}`;
---

<BaseLayout title={`${displayIssueTitle} | Nexus`}>
  <article class="issue-shell">
    <a class="back" href="/nexus">← Back to nexus</a>
    <header class="head">
      <TypeBadge type="nexus" />
      <h1>{displayIssueTitle}</h1>
      {issue.data.excerpt && <p class="excerpt">{issue.data.excerpt}</p>}
      {issue.data.themeStatement && <p class="statement">{issue.data.themeStatement}</p>}
      <div class="meta">
        <span>{formatArchiveLongDate(issue.data.date)}</span>
        {issue.data.releaseType && <span>{issue.data.releaseType}</span>}
        <span>{issue.data.includedObjects.length} items</span>
      </div>
    </header>

    <section class="sequence">
      <h2>Reading Sequence</h2>
      <ol>
        {sequence.map((item) => (
          <li>
            <div class="seq-num">{String(item.index).padStart(2, '0')}</div>
            <div class="seq-main">
              <p class="role">{item.role}</p>
              <a href={`/objects/${item.ref}${nexusContextQuery}`}>
                {item.entry?.data.title ? formatDisplayTitle(item.entry.data.title) : item.ref}
              </a>
              {item.entry?.data.excerpt && <p class="preview">{item.entry.data.excerpt}</p>}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="body">
      <Content />
    </section>
  </article>

  <nav class="pager">
    {newerIssue ? (
      <a href={`/nexus/${newerIssue.data.id}`}>← Newer: {formatDisplayTitle(newerIssue.data.title)}</a>
    ) : (
      <span></span>
    )}
    {olderIssue ? (
      <a href={`/nexus/${olderIssue.data.id}`}>Older: {formatDisplayTitle(olderIssue.data.title)} →</a>
    ) : (
      <span></span>
    )}
  </nav>
</BaseLayout>

<style>
  .issue-shell {
    padding: 4.4rem 0 5.6rem;
    background: transparent;
  }

  .back {
    display: inline-block;
    color: var(--mid);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-ui);
    padding: 0;
    transition: 0.12s;
  }

  .back:hover {
    color: var(--star);
  }

  .head h1 {
    margin: 0.9rem 0 1.05rem;
    line-height: 1.3;
  }

  .excerpt,
  .statement {
    margin: 0;
    color: var(--text-body);
    line-height: 1.9;
    font-size: 1.18rem;
    max-width: 40ch;
  }

  .statement {
    margin-top: 0.8rem;
    color: var(--accent-quote-soft);
    font-size: 1.16rem;
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.004em;
  }

  .meta {
    margin-top: 1.8rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.7rem;
  }

  .meta span {
    padding: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: var(--ls-ui);
  }

  .meta span + span {
    position: relative;
    padding-left: 0.72rem;
  }

  .meta span + span::before {
    content: '·';
    position: absolute;
    left: 0.12rem;
    color: var(--ghost);
  }

  .sequence {
    margin-top: 4.2rem;
    padding-top: 0.2rem;
  }

  .sequence h2 {
    margin: 0 0 1.65rem;
    color: var(--mid);
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 600;
    letter-spacing: var(--ls-title);
  }

  .sequence ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sequence li {
    padding: 2rem 0;
    display: grid;
    grid-template-columns: 3.1rem 1fr;
    gap: 1.6rem;
    transition: 0.12s;
  }

  .sequence li + li {
    margin-top: 1.2rem;
  }

  .sequence li:hover .seq-num {
    color: var(--goldd);
  }

  .sequence li:hover .seq-main a {
    color: var(--gold);
  }

  .seq-num {
    color: var(--dim);
    font-size: clamp(2.2rem, 5vw, 2.9rem);
    font-weight: 900;
    line-height: 1;
    padding-top: 0.05rem;
  }

  .role {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-ui);
  }

  .seq-main a {
    color: var(--star);
    text-decoration: none;
    font-size: clamp(1.5rem, 2.8vw, 2.1rem);
    font-style: normal;
    line-height: 1.25;
    font-weight: 600;
  }

  .seq-main a:hover {
    color: var(--gold);
  }

  .preview {
    margin: 0.82rem 0 0;
    color: var(--text-body);
    font-size: 1.12rem;
    line-height: 1.9;
    max-width: 44ch;
  }

  .body {
    margin-top: 4.2rem;
    line-height: 2;
    padding-top: 0.2rem;
  }

  .body :global(p) {
    margin: 0 0 2rem;
    color: var(--text-body);
    font-style: normal;
    font-size: 1.15rem;
  }

  .pager {
    margin-top: 3.4rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pager a {
    color: var(--mid);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 12px;
    letter-spacing: var(--ls-ui);
    padding: 0;
    transition: 0.12s;
  }

  .pager a:hover {
    color: var(--star);
  }

  .pager span {
    min-height: 24px;
  }
</style>
