---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  socialImage?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
  socialType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
}

const {
  title = 'Codex Archive',
  description = 'An object archive for human creative work.',
  canonicalPath,
  socialImage,
  socialImageWidth,
  socialImageHeight,
  socialType = 'website',
  twitterCard,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteBase = Astro.site ? new URL(Astro.site.toString()) : new URL(Astro.url.origin);
const defaultSocialImage = '/social/ndcodex-minimal-og.png';

function toAbsoluteUrl(value: string): string {
  if (/^https?:\/\//i.test(value)) {
    return value;
  }
  return new URL(value, siteBase).toString();
}

function normalizeCanonicalUrl(value: string): string {
  const absolute = new URL(toAbsoluteUrl(value));
  const isFileLikePath = /\.[a-z0-9]+$/i.test(absolute.pathname);

  if (absolute.pathname !== '/' && !isFileLikePath && !absolute.pathname.endsWith('/')) {
    absolute.pathname = `${absolute.pathname}/`;
  }

  return absolute.toString();
}

const canonicalUrl = normalizeCanonicalUrl(canonicalPath || currentPath);
const socialImageUrl = toAbsoluteUrl(socialImage || defaultSocialImage);
const rssFeedUrl = toAbsoluteUrl('/rss.xml');
const jsonFeedUrl = toAbsoluteUrl('/feed.json');
const siteHomeUrl = toAbsoluteUrl('/');
const resolvedTwitterCard = twitterCard || 'summary';
const hasSocialImageDimensions =
  typeof socialImageWidth === 'number' &&
  Number.isFinite(socialImageWidth) &&
  typeof socialImageHeight === 'number' &&
  Number.isFinite(socialImageHeight);
const feedActive = currentPath === '/' || currentPath.startsWith('/objects/');
const nexusActive = currentPath.startsWith('/nexus');
const graphActive = currentPath.startsWith('/graph');
const orientationActive = currentPath.startsWith('/orientation');
const homeFeed = currentPath === '/';

const navItems = [
  { href: '/', label: 'Feed', active: feedActive },
  { href: '/orientation', label: 'Orientation', active: orientationActive },
  { href: '/nexus', label: 'Nexus', active: nexusActive },
  { href: '/graph', label: 'Graph', active: graphActive },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Codex Archive" />
    <meta property="og:type" content={socialType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    {hasSocialImageDimensions && (
      <>
        <meta property="og:image:width" content={String(socialImageWidth)} />
        <meta property="og:image:height" content={String(socialImageHeight)} />
      </>
    )}
    <meta property="og:image:alt" content="ndcodex.com" />
    <meta name="twitter:card" content={resolvedTwitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="alternate" type="application/rss+xml" title="Codex Archive RSS Feed" href={rssFeedUrl} />
    <link rel="alternate" type="application/feed+json" title="Codex Archive JSON Feed" href={jsonFeedUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class={homeFeed ? 'page-feed' : undefined}>
    <div class="noise"></div>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">Codex Archive</a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a class={item.active ? 'active' : ''} href={item.href}>{item.label}</a>
          ))}
        </nav>
        <span class="site-sigil" aria-hidden="true">✦</span>
      </div>
    </header>
    <script is:inline>
      (() => {
        const header = document.querySelector('.site-header');
        if (!(header instanceof HTMLElement)) return;

        let lastY = window.scrollY;
        let ticking = false;
        const body = document.body;
        const floatThreshold = 8;
        const floatRange = 112;
        const hideThreshold = 124;
        const directionThreshold = 4;

        const updateHeaderState = () => {
          const currentY = window.scrollY;
          const delta = currentY - lastY;
          const floatProgress = Math.max(0, Math.min((currentY - floatThreshold) / floatRange, 1));
          const isCondensed = floatProgress > 0.02;

          header.classList.toggle('is-condensed', isCondensed);

          if (!isCondensed) {
            header.classList.remove('is-hidden');
          } else if (currentY > hideThreshold && delta > directionThreshold) {
            header.classList.add('is-hidden');
          } else if (delta < -directionThreshold || currentY <= hideThreshold) {
            header.classList.remove('is-hidden');
          }

          const isHidden = header.classList.contains('is-hidden');
          body.style.setProperty('--header-float-progress', floatProgress.toFixed(3));
          body.style.setProperty('--header-hidden-progress', isHidden ? '1' : '0');

          lastY = currentY;
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateHeaderState);
        };

        updateHeaderState();
        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestUpdate);
        window.addEventListener('pageshow', requestUpdate);
      })();
    </script>
    <main class="shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <p class="site-footer-label">Follow</p>
        <p class="site-footer-copy">
          Paste the site URL into most readers. Direct feeds are available if your reader wants them explicitly.
        </p>
        <div class="site-footer-links">
          <a href={siteHomeUrl}>Site URL</a>
          <a href={rssFeedUrl}>RSS</a>
          <a href={jsonFeedUrl}>JSON Feed</a>
        </div>
      </div>
    </footer>

    <div class="card-image-lightbox" data-card-image-lightbox hidden aria-hidden="true">
      <div class="card-image-lightbox-topbar">
        <p class="card-image-lightbox-count" data-card-image-lightbox-count hidden aria-live="polite"></p>
        <a class="card-image-lightbox-link" href="/" data-card-image-lightbox-link>
          Open attached post
        </a>
        <button
          class="card-image-lightbox-close"
          type="button"
          data-card-image-lightbox-close
          aria-label="Close expanded card image"
        >
          Close
        </button>
      </div>
      <figure class="card-image-lightbox-frame">
        <button
          class="card-image-lightbox-nav card-image-lightbox-nav--prev"
          type="button"
          data-card-image-lightbox-prev
          aria-label="Show previous image"
          hidden
        >
          Prev
        </button>
        <img src="" alt="" data-card-image-lightbox-image />
        <button
          class="card-image-lightbox-nav card-image-lightbox-nav--next"
          type="button"
          data-card-image-lightbox-next
          aria-label="Show next image"
          hidden
        >
          Next
        </button>
        <figcaption data-card-image-lightbox-caption hidden></figcaption>
      </figure>
    </div>

    <script is:inline>
      (() => {
        const lightbox = document.querySelector('[data-card-image-lightbox]');
        if (!(lightbox instanceof HTMLElement)) return;

        const lightboxImage = lightbox.querySelector('[data-card-image-lightbox-image]');
        const lightboxCaption = lightbox.querySelector('[data-card-image-lightbox-caption]');
        const lightboxCount = lightbox.querySelector('[data-card-image-lightbox-count]');
        const lightboxLink = lightbox.querySelector('[data-card-image-lightbox-link]');
        const closeButton = lightbox.querySelector('[data-card-image-lightbox-close]');
        const prevButton = lightbox.querySelector('[data-card-image-lightbox-prev]');
        const nextButton = lightbox.querySelector('[data-card-image-lightbox-next]');
        const lightboxFrame = lightbox.querySelector('.card-image-lightbox-frame');

        if (!(lightboxImage instanceof HTMLImageElement)) return;
        if (!(lightboxCaption instanceof HTMLElement)) return;
        if (!(lightboxCount instanceof HTMLElement)) return;
        if (!(lightboxLink instanceof HTMLAnchorElement)) return;
        if (!(prevButton instanceof HTMLButtonElement)) return;
        if (!(nextButton instanceof HTMLButtonElement)) return;
        if (!(lightboxFrame instanceof HTMLElement)) return;

        const triggers = Array.from(document.querySelectorAll('[data-card-image-trigger="true"]')).filter(
          (node) => node instanceof HTMLElement
        );
        if (!triggers.length) return;

        let lastFocusedTrigger = null;
        let previousOverflow = '';
        let activeGallery = [];
        let activeIndex = -1;
        let touchStartX = 0;
        let touchStartY = 0;
        let isTransitioning = false;
        let transitionSwapTimeout = 0;
        let transitionCleanupTimeout = 0;
        let lastGestureNavigationAt = 0;
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        const mobileTapNavigationQuery = window.matchMedia('(max-width: 600px)');

        const clearTransitionTimers = () => {
          if (transitionSwapTimeout) {
            window.clearTimeout(transitionSwapTimeout);
            transitionSwapTimeout = 0;
          }

          if (transitionCleanupTimeout) {
            window.clearTimeout(transitionCleanupTimeout);
            transitionCleanupTimeout = 0;
          }
        };

        const clearTransitionState = () => {
          clearTransitionTimers();
          isTransitioning = false;
          lightboxFrame.classList.remove('is-transitioning-out', 'is-transitioning-in', 'is-forward', 'is-backward');
        };

        const syncNavState = () => {
          const hasGallery = activeGallery.length > 1;
          const atStart = activeIndex <= 0;
          const atEnd = activeIndex >= activeGallery.length - 1;

          lightbox.classList.toggle('is-gallery', hasGallery);
          prevButton.hidden = !hasGallery;
          nextButton.hidden = !hasGallery;
          prevButton.disabled = !hasGallery || atStart;
          nextButton.disabled = !hasGallery || atEnd;

          if (hasGallery && activeIndex >= 0) {
            lightboxCount.textContent = `${activeIndex + 1} / ${activeGallery.length}`;
            lightboxCount.hidden = false;
          } else {
            lightboxCount.textContent = '';
            lightboxCount.hidden = true;
          }
        };

        const applyGalleryIndex = (index) => {
          const item = activeGallery[index];
          if (!item || typeof item.src !== 'string' || !item.src) return;

          activeIndex = index;
          lightboxImage.src = item.src;
          lightboxImage.alt = typeof item.alt === 'string' && item.alt ? item.alt : 'Expanded image';

          const caption = typeof item.caption === 'string' ? item.caption : '';
          if (caption) {
            lightboxCaption.textContent = caption;
            lightboxCaption.hidden = false;
          } else {
            lightboxCaption.textContent = '';
            lightboxCaption.hidden = true;
          }

          syncNavState();
        };

        const renderGalleryIndex = (index, direction = 0) => {
          const item = activeGallery[index];
          if (!item || typeof item.src !== 'string' || !item.src) return;

          const shouldAnimate =
            direction !== 0 &&
            !lightbox.hidden &&
            !reducedMotionQuery.matches;

          if (!shouldAnimate) {
            clearTransitionState();
            applyGalleryIndex(index);
            return;
          }

          clearTransitionState();
          isTransitioning = true;
          lightboxFrame.classList.add('is-transitioning-out', direction > 0 ? 'is-forward' : 'is-backward');

          transitionSwapTimeout = window.setTimeout(() => {
            applyGalleryIndex(index);
            lightboxFrame.classList.remove('is-transitioning-out');
            lightboxFrame.classList.add('is-transitioning-in');

            transitionCleanupTimeout = window.setTimeout(() => {
              clearTransitionState();
            }, 240);
          }, 120);
        };

        const stepGallery = (direction) => {
          if (activeIndex < 0 || isTransitioning) return;

          const nextIndex = activeIndex + direction;
          if (nextIndex < 0 || nextIndex >= activeGallery.length) return;

          renderGalleryIndex(nextIndex, direction);
        };

        const readTriggerGallery = (trigger) => {
          const rawItems = trigger.getAttribute('data-card-lightbox-images');
          if (rawItems) {
            try {
              const parsed = JSON.parse(rawItems);
              if (Array.isArray(parsed)) {
                const sanitized = parsed.filter(
                  (item) => item && typeof item === 'object' && typeof item.src === 'string' && item.src
                );
                if (sanitized.length > 0) {
                  return sanitized;
                }
              }
            } catch {}
          }

          const source = trigger.getAttribute('data-card-lightbox-src');
          if (!source) return [];

          return [{
            src: source,
            alt: trigger.getAttribute('data-card-lightbox-alt') || 'Expanded image',
            caption: trigger.getAttribute('data-card-lightbox-caption') || '',
          }];
        };

        const closeLightbox = () => {
          if (lightbox.hidden) return;

          lightbox.hidden = true;
          lightbox.setAttribute('aria-hidden', 'true');
          lightboxImage.removeAttribute('src');
          lightboxImage.removeAttribute('alt');
          lightboxCaption.textContent = '';
          lightboxCaption.hidden = true;
          lightboxCount.textContent = '';
          lightboxCount.hidden = true;
          lightboxLink.href = '/';
          lightboxLink.textContent = 'Open attached post';
          lightboxLink.setAttribute('aria-label', 'Open attached post');
          lightbox.classList.remove('is-gallery');
          clearTransitionState();
          activeGallery = [];
          activeIndex = -1;
          document.body.style.overflow = previousOverflow;

          if (lastFocusedTrigger instanceof HTMLElement) {
            lastFocusedTrigger.focus();
          }
        };

        const openLightbox = (trigger) => {
          const gallery = readTriggerGallery(trigger);
          if (!gallery.length) return;

          previousOverflow = document.body.style.overflow;
          document.body.style.overflow = 'hidden';
          lastFocusedTrigger = trigger;
          activeGallery = gallery;
          clearTransitionState();
          renderGalleryIndex(0);

          const href = trigger.getAttribute('data-card-lightbox-href') || '/';
          const title = trigger.getAttribute('data-card-lightbox-title') || 'attached post';
          lightboxLink.href = href;
          lightboxLink.textContent = 'Open attached post';
          lightboxLink.setAttribute('aria-label', `Open ${title}`);

          lightbox.hidden = false;
          lightbox.setAttribute('aria-hidden', 'false');
        };

        triggers.forEach((trigger) => {
          if (!(trigger instanceof HTMLElement)) return;

          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            openLightbox(trigger);
          });

          trigger.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              openLightbox(trigger);
            }
          });
        });

        closeButton?.addEventListener('click', closeLightbox);
        prevButton.addEventListener('click', () => stepGallery(-1));
        nextButton.addEventListener('click', () => stepGallery(1));

        lightbox.addEventListener('click', (event) => {
          if (event.target === lightbox) {
            closeLightbox();
          }
        });

        lightboxFrame.addEventListener(
          'touchstart',
          (event) => {
            const touch = event.touches[0];
            if (!touch) return;
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
          },
          { passive: true }
        );

        lightboxFrame.addEventListener(
          'touchend',
          (event) => {
            const touch = event.changedTouches[0];
            if (!touch) return;

            const deltaX = touch.clientX - touchStartX;
            const deltaY = touch.clientY - touchStartY;
          if (Math.abs(deltaX) < 48 || Math.abs(deltaX) <= Math.abs(deltaY)) return;

          lastGestureNavigationAt = Date.now();
          if (deltaX < 0) {
            stepGallery(1);
          } else {
            stepGallery(-1);
          }
          },
          { passive: true }
        );

        lightboxFrame.addEventListener('click', (event) => {
          if (lightbox.hidden) return;
          if (!mobileTapNavigationQuery.matches) return;
          if (activeGallery.length <= 1 || isTransitioning) return;
          if (Date.now() - lastGestureNavigationAt < 360) return;
          if (event.target instanceof HTMLElement && event.target.closest('button, a, figcaption')) return;

          const captionRect = lightboxCaption.hidden ? null : lightboxCaption.getBoundingClientRect();
          if (captionRect && event.clientY >= captionRect.top) return;

          const frameRect = lightboxFrame.getBoundingClientRect();
          const midpoint = frameRect.left + frameRect.width / 2;
          if (event.clientX < midpoint) {
            stepGallery(-1);
          } else {
            stepGallery(1);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeLightbox();
            return;
          }

          if (lightbox.hidden) return;

          if (event.key === 'ArrowLeft') {
            event.preventDefault();
            stepGallery(-1);
          }

          if (event.key === 'ArrowRight') {
            event.preventDefault();
            stepGallery(1);
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --ink: #0e0c0a;
    --parchment: #f4f0e8;
    --bone: #e8e2d4;
    --rust: #c4623a;
    --ash: #9f9488;
    --gold: #c9963a;
    --dim: #433a31;
    --ghost: #6f6256;
    --rust-dark: #8b3a1e;
    --void: var(--ink);
    --deep: #12100d;
    --surface: #17130f;
    --line: #3b332b;
    --mid: #b8ada0;
    --pale: var(--bone);
    --star: var(--parchment);
    --goldd: var(--rust-dark);
    --green: #8ca996;
    --ember: #d2744f;
    --text-strong: var(--star);
    --text-body: var(--bone);
    --text-dim: var(--mid);
    --accent: var(--rust);
    --accent-quote: #d8bc84;
    --accent-quote-soft: rgba(216, 188, 132, 0.86);
    --accent-quote-strong: #e5c98d;
    --font-display:
      'Playfair Display',
      'Times New Roman',
      serif;
    --font-body:
      'Libre Baskerville',
      Georgia,
      serif;
    --font-ui:
      'Space Mono',
      'Courier New',
      monospace;
    --gutter: clamp(2.1rem, 5.2vw, 6.2rem);
    --content-max: 1220px;
    --ls-display: -0.016em;
    --ls-title: -0.012em;
    --ls-ui: 0.07em;
    --ls-ui-wide: 0.11em;
    --ls-label: 0.14em;
    --page-title-size-mobile: 2.2rem;
    --page-title-size-tablet: 2.72rem;
    --page-title-size-desktop: 3.18rem;
    --page-title-leading: 1.05;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    --header-float-progress: 0;
    --header-hidden-progress: 0;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.9;
    color: var(--text-body);
    background: var(--void);
    position: relative;
    isolation: isolate;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    background:
      radial-gradient(circle at 84% -12%, rgba(196, 98, 58, 0.14), transparent 44%),
      radial-gradient(circle at 8% 112%, rgba(201, 150, 58, 0.08), transparent 42%),
      var(--void);
  }

  button,
  input,
  textarea {
    font-family: var(--font-ui);
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: var(--ls-display);
  }

  :global(.feed-thesis),
  :global(.graph-meta h1),
  :global(.orientation-hero h1),
  :global(.issues .issue h2),
  :global(.issue-shell .head h1),
  :global(.object-head h1) {
    color: var(--star);
    font-size: var(--page-title-size-mobile);
    font-style: normal;
    font-weight: 600;
    line-height: var(--page-title-leading);
    letter-spacing: var(--ls-display);
    text-wrap: balance;
  }

  .noise {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.018;
    background-image: radial-gradient(circle at 1px 1px, #d3cb9d 1px, transparent 0);
    background-size: 3px 3px;
  }

  .site-header {
    --header-peek: 0.72rem;
    --header-shadow-progress: calc(
      (var(--header-float-progress) * 0.84) + (var(--header-hidden-progress) * 0.16)
    );
    position: sticky;
    top: 0;
    z-index: 60;
    padding: 1.38rem var(--gutter) 1.12rem;
    background-color: rgb(
      14 12 10 / calc(0.9 + (0.045 * var(--header-float-progress)) + (0.025 * var(--header-hidden-progress)))
    );
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow:
      inset 0 -1px 0 rgb(135 91 58 / calc(0.2 + (0.08 * var(--header-shadow-progress)))),
      0 calc(2px + (6px * var(--header-shadow-progress)))
        calc(6px + (14px * var(--header-shadow-progress)))
        rgb(0 0 0 / calc(0.015 + (0.11 * var(--header-shadow-progress))));
    transition:
      transform 150ms cubic-bezier(0.32, 0.94, 0.32, 1),
      background-color 160ms linear,
      box-shadow 160ms linear;
    will-change: transform;
  }

  .site-header::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2.35rem;
    height: 2.5rem;
    pointer-events: none;
    opacity: calc((0.76 * var(--header-float-progress)) + (0.18 * var(--header-hidden-progress)));
    background:
      linear-gradient(
        to bottom,
        rgba(14, 12, 10, 0.34) 0%,
        rgba(14, 12, 10, 0.16) 42%,
        rgba(14, 12, 10, 0.05) 72%,
        rgba(14, 12, 10, 0) 100%
      );
    transition: opacity 160ms linear;
  }

  .site-header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1rem;
    height: 1rem;
    pointer-events: none;
    opacity: calc((0.62 * var(--header-float-progress)) + (0.14 * var(--header-hidden-progress)));
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.22), transparent 78%);
    transition: opacity 160ms linear;
  }

  .site-header.is-hidden {
    transform: translate3d(0, calc(-100% + var(--header-peek)), 0);
  }

  .site-header-inner {
    width: min(100%, 1480px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
  }

  .brand {
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
    text-decoration: none;
    white-space: nowrap;
  }

  .brand:visited,
  .brand:hover,
  .brand:active {
    color: var(--ash);
    text-decoration: none;
  }

  .site-nav {
    display: inline-flex;
    gap: 1.4rem;
    align-items: center;
    margin-left: auto;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--mid);
    font-family: var(--font-ui);
    border: none;
    border-bottom: 1px solid transparent;
    border-radius: 0;
