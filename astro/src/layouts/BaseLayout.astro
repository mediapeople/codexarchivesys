---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  socialImage?: string;
  socialType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
}

const {
  title = 'Codex Archive',
  description = 'Object-first archive for scrolls, artifacts, field logs, codexes, fragments, nexus issues, and signals.',
  canonicalPath,
  socialImage,
  socialType = 'website',
  twitterCard,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteBase = Astro.site ? new URL(Astro.site.toString()) : new URL(Astro.url.origin);
const defaultSocialImage = '/social/ndcodex-minimal-og.png';

function toAbsoluteUrl(value: string): string {
  if (/^https?:\/\//i.test(value)) {
    return value;
  }
  return new URL(value, siteBase).toString();
}

const canonicalUrl = toAbsoluteUrl(canonicalPath || currentPath);
const socialImageUrl = toAbsoluteUrl(socialImage || defaultSocialImage);
const resolvedTwitterCard = twitterCard || 'summary';
const feedActive = currentPath === '/' || currentPath.startsWith('/objects/');
const nexusActive = currentPath.startsWith('/nexus');
const graphActive = currentPath.startsWith('/graph');
const orientationActive = currentPath.startsWith('/orientation');
const homeFeed = currentPath === '/';

const navItems = [
  { href: '/', label: 'Feed', active: feedActive },
  { href: '/orientation', label: 'Orientation', active: orientationActive },
  { href: '/nexus', label: 'Nexus', active: nexusActive },
  { href: '/graph', label: 'Graph', active: graphActive },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Codex Archive" />
    <meta property="og:type" content={socialType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ndcodex.com" />
    <meta name="twitter:card" content={resolvedTwitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class={homeFeed ? 'page-feed' : undefined}>
    <div class="noise"></div>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">Codex Archive System</a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a class={item.active ? 'active' : ''} href={item.href}>{item.label}</a>
          ))}
        </nav>
        <span class="site-sigil" aria-hidden="true">✦</span>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --ink: #0e0c0a;
    --parchment: #f4f0e8;
    --bone: #e8e2d4;
    --rust: #c4623a;
    --ash: #9f9488;
    --gold: #c9963a;
    --dim: #433a31;
    --ghost: #6f6256;
    --rust-dark: #8b3a1e;
    --void: var(--ink);
    --deep: #12100d;
    --surface: #17130f;
    --line: #3b332b;
    --mid: #b8ada0;
    --pale: var(--bone);
    --star: var(--parchment);
    --goldd: var(--rust-dark);
    --green: #8ca996;
    --ember: #d2744f;
    --text-strong: var(--star);
    --text-body: var(--bone);
    --text-dim: var(--mid);
    --accent: var(--rust);
    --accent-quote: #d8bc84;
    --accent-quote-soft: rgba(216, 188, 132, 0.86);
    --accent-quote-strong: #e5c98d;
    --font-display:
      'Playfair Display',
      'Times New Roman',
      serif;
    --font-body:
      'Libre Baskerville',
      Georgia,
      serif;
    --font-ui:
      'Space Mono',
      'Courier New',
      monospace;
    --gutter: clamp(2.1rem, 5.2vw, 6.2rem);
    --content-max: 1220px;
    --ls-display: -0.016em;
    --ls-title: -0.012em;
    --ls-ui: 0.07em;
    --ls-ui-wide: 0.11em;
    --ls-label: 0.14em;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.9;
    color: var(--text-body);
    background: var(--void);
    position: relative;
    isolation: isolate;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    background:
      radial-gradient(circle at 84% -12%, rgba(196, 98, 58, 0.14), transparent 44%),
      radial-gradient(circle at 8% 112%, rgba(201, 150, 58, 0.08), transparent 42%),
      var(--void);
  }

  button,
  input,
  textarea {
    font-family: var(--font-ui);
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: var(--ls-display);
  }

  .noise {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.018;
    background-image: radial-gradient(circle at 1px 1px, #d3cb9d 1px, transparent 0);
    background-size: 3px 3px;
  }

  .site-header {
    position: relative;
    top: auto;
    z-index: 40;
    padding: 1.38rem var(--gutter) 1.12rem;
    background: rgba(14, 12, 10, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: inset 0 -1px 0 rgba(135, 91, 58, 0.2);
  }

  .site-header-inner {
    width: min(100%, 1480px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
  }

  .brand {
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
    text-decoration: none;
    white-space: nowrap;
  }

  .brand:visited,
  .brand:hover,
  .brand:active {
    color: var(--ash);
    text-decoration: none;
  }

  .site-nav {
    display: inline-flex;
    gap: 1.4rem;
    align-items: center;
    margin-left: auto;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--mid);
    font-family: var(--font-ui);
    border: none;
    border-bottom: 1px solid transparent;
    border-radius: 0;
    padding: 0.12rem 0 0.26rem;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: 0.15s;
  }

  .site-nav a:hover {
    color: var(--star);
    border-bottom-color: rgba(255, 255, 255, 0.22);
  }

  .site-nav a.active {
    color: var(--parchment);
    border-bottom-color: var(--rust);
  }

  .site-sigil {
    color: var(--gold);
    font-family: var(--font-display);
    font-size: 0.98rem;
    line-height: 1;
    flex: 0 0 auto;
  }

  .shell {
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--gutter) 7rem;
    position: relative;
    overflow-x: clip;
  }

  body.page-feed .shell::after {
    content: '';
    position: absolute;
    top: clamp(-9rem, -6.5vw, -3.6rem);
    left: 50%;
    transform: translateX(-50%);
    width: min(2680px, 188vw);
    height: clamp(26rem, 56vw, 52rem);
    pointer-events: none;
    z-index: 0;
    opacity: 0.17;
    background: url('/media/decor/feed-hero-swoosh.svg') no-repeat 58% 34% / 142% 142%;
  }

  .shell > * {
    width: 100%;
    max-width: var(--content-max);
    margin-left: auto !important;
    margin-right: auto !important;
    padding-left: 0;
    padding-right: 0;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    body.page-feed {
      --gutter: 1rem;
    }

    .site-header {
      padding: 0.95rem 1.25rem 0.82rem;
    }

    .site-header-inner {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'brand sigil'
        'nav nav';
      row-gap: 0.72rem;
    }

    .brand {
      grid-area: brand;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
    }

    .site-sigil {
      grid-area: sigil;
      justify-self: end;
    }

    .site-nav {
      grid-area: nav;
      flex-wrap: wrap;
      width: 100%;
      margin-left: 0;
      gap: 1rem;
      border-top: 1px solid rgba(135, 91, 58, 0.2);
      padding-top: 0.62rem;
    }

    .site-nav a {
      font-size: 0.68rem;
      letter-spacing: 0.14em;
    }

    body.page-feed .shell::after {
      top: -4.8rem;
      width: 255vw;
      height: 21rem;
      opacity: 0.12;
      background-size: 176% 176%;
      background-position: 62% 30%;
    }
  }

  @media (max-width: 420px) {
    body.page-feed {
      --gutter: 0.82rem;
    }
  }
</style>
