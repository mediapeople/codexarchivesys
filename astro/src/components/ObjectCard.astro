---
import TypeBadge from './TypeBadge.astro';
import type { ArchiveEntry } from '../lib/archive';
import { formatMediaLabel, getMediaItems, pickPrimaryMedia } from '../lib/media';
import { formatDisplayTitle } from '../lib/headline';
import { getAuthorInitials, getPrimaryAuthor } from '../lib/author';
import { formatArchiveDate } from '../lib/timeline';

interface Props {
  entry: ArchiveEntry;
  href?: string;
  relationScore?: number;
  variant?: 'feed' | 'related' | 'mosaic';
}

const {
  entry,
  href = `/objects/${entry.data.id}`,
  relationScore,
  variant = 'feed',
} = Astro.props;
const mediaItems = getMediaItems(entry);
const primaryMedia = pickPrimaryMedia(mediaItems);
const displayTitle = formatDisplayTitle(entry.data.title);
const primaryAuthor = getPrimaryAuthor(entry);
const authorInitials = getAuthorInitials(primaryAuthor.name);
const authorDesignation = primaryAuthor.designation || primaryAuthor.role || 'Archive operator';

function normalizeForCompare(value: string): string {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
}

const fallbackSummary = (entry.data as Record<string, unknown>).themeStatement;
const rawSummary =
  entry.data.excerpt ||
  (typeof fallbackSummary === 'string' ? fallbackSummary : '');
const summaryText = normalizeForCompare(rawSummary) ? rawSummary : '';
const searchCorpus = [displayTitle, summaryText, ...entry.data.themes, ...entry.data.constellations]
  .join(' ')
  .toLowerCase();

const readableDate = formatArchiveDate(entry.data.date);
---

<article
  class={`card ${entry.collection} ${variant}`}
  data-type={entry.collection}
  data-themes={entry.data.themes.join('|').toLowerCase()}
  data-search={searchCorpus}
>
  <a class="hitbox" href={href} aria-label={`Open ${entry.data.title}`}></a>
  <div class="preview-wrap">
    {primaryMedia?.kind === 'image' ? (
      <img
        class="preview-image"
        src={primaryMedia.src}
        alt={primaryMedia.alt || `${entry.data.title} media preview`}
        loading="lazy"
        decoding="async"
      />
    ) : primaryMedia ? (
      <div class="preview-fallback">
        <span>{primaryMedia.kind}</span>
        <small>{formatMediaLabel(primaryMedia)}</small>
      </div>
    ) : (
      <div class={`preview-empty ${entry.collection}`}>
        <span>{entry.collection}</span>
      </div>
    )}
  </div>
  <header class="meta">
    <TypeBadge type={entry.collection} />
    {variant !== 'mosaic' && <span class="date">{readableDate}</span>}
    {variant === 'related' && relationScore !== undefined && <span class="score">{relationScore} signals</span>}
  </header>
  <h3 class="title">{displayTitle}</h3>
  {summaryText && <p class="excerpt">{summaryText}</p>}
  {entry.data.themes.length > 0 && variant !== 'mosaic' && (
    <ul class="themes">
      {entry.data.themes.slice(0, 3).map((theme) => (
        <li>{theme}</li>
      ))}
    </ul>
  )}
  <div class="author-tease">
    <div class="author-thumb" aria-hidden="true">
      {primaryAuthor.avatar ? (
        <img src={primaryAuthor.avatar} alt="" loading="lazy" decoding="async" />
      ) : (
        <span>{authorInitials}</span>
      )}
    </div>
    <p class="author-name">
      <span class="name">{primaryAuthor.name}</span>
      <span class="designation">, {authorDesignation}</span>
    </p>
  </div>
</article>

<style>
  .card {
    --type-accent: var(--ghost);
    --placeholder-surface:
      linear-gradient(150deg, rgba(60, 53, 46, 0.24), rgba(18, 16, 14, 0.9));
    --placeholder-motif: radial-gradient(circle at center, rgba(255, 255, 255, 0.04), transparent 62%);
    --placeholder-label: rgba(231, 222, 209, 0.76);
    position: relative;
    display: grid;
    column-gap: 3.2rem;
    border: none;
    border-radius: 0;
    padding: 3.2rem clamp(0.7rem, 1.3vw, 1.2rem) 3.8rem;
    background: transparent;
    transition: transform 120ms ease;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-1px);
  }

  .card.feed {
    grid-template-columns: minmax(0, 1fr) minmax(340px, 42%);
    padding-left: 0;
    padding-right: 0;
    padding-top: 1.9rem;
    padding-bottom: 2.2rem;
  }

  .card.related {
    grid-template-columns: minmax(0, 1fr) minmax(320px, 40%);
    column-gap: 4.8rem;
    row-gap: 1.2rem;
    padding-top: 1.8rem;
    padding-bottom: 2rem;
  }

  .card.mosaic {
    grid-template-columns: 1fr;
    row-gap: 0.72rem;
    column-gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 2px;
    padding: 0.7rem 0.75rem 0.86rem;
    background:
      linear-gradient(170deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0)),
      rgba(14, 12, 10, 0.6);
  }

  .card.scroll {
    --type-accent: rgba(196, 98, 58, 0.85);
    --placeholder-surface:
      linear-gradient(152deg, rgba(196, 98, 58, 0.16), rgba(20, 18, 16, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(180deg, rgba(244, 240, 232, 0.055) 0 1px, transparent 1px 14px),
      linear-gradient(90deg, rgba(196, 98, 58, 0.08), transparent 62%);
  }

  .card.artifact {
    --type-accent: rgba(201, 150, 58, 0.88);
    --placeholder-surface:
      linear-gradient(150deg, rgba(201, 150, 58, 0.17), rgba(22, 19, 16, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(45deg, rgba(233, 201, 140, 0.05) 0 1px, transparent 1px 12px),
      repeating-linear-gradient(-45deg, rgba(233, 201, 140, 0.035) 0 1px, transparent 1px 14px);
  }

  .card.fieldlog {
    --type-accent: rgba(138, 132, 128, 0.8);
    --placeholder-surface:
      linear-gradient(150deg, rgba(138, 132, 128, 0.18), rgba(20, 18, 16, 0.9));
    --placeholder-motif:
      repeating-linear-gradient(0deg, rgba(232, 226, 212, 0.045) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(90deg, rgba(232, 226, 212, 0.04) 0 1px, transparent 1px 16px);
  }

  .card.codex {
    --type-accent: rgba(201, 150, 58, 0.7);
    --placeholder-surface:
      linear-gradient(150deg, rgba(184, 153, 102, 0.15), rgba(19, 17, 15, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(90deg, rgba(229, 196, 134, 0.045) 0 2px, transparent 2px 28px),
      linear-gradient(180deg, rgba(233, 201, 140, 0.045), transparent 60%);
  }

  .card.fragment {
    --type-accent: rgba(92, 84, 80, 0.86);
    --placeholder-surface:
      linear-gradient(150deg, rgba(92, 84, 80, 0.22), rgba(20, 18, 16, 0.9));
    --placeholder-motif:
      repeating-linear-gradient(132deg, rgba(215, 196, 167, 0.042) 0 1px, transparent 1px 13px),
      repeating-linear-gradient(168deg, rgba(215, 196, 167, 0.03) 0 1px, transparent 1px 21px);
  }

  .card.nexus {
    --type-accent: var(--rust);
    --placeholder-surface:
      linear-gradient(150deg, rgba(196, 98, 58, 0.2), rgba(24, 18, 16, 0.94));
    --placeholder-motif:
      radial-gradient(circle at 50% 50%, transparent 0 16%, rgba(231, 171, 130, 0.08) 16% 17%, transparent 17% 33%, rgba(231, 171, 130, 0.06) 33% 34%, transparent 34% 100%),
      linear-gradient(0deg, rgba(196, 98, 58, 0.07), transparent 58%);
  }

  .card.signal {
    --type-accent: rgba(132, 176, 158, 0.82);
    --placeholder-surface:
      linear-gradient(150deg, rgba(100, 148, 131, 0.18), rgba(18, 23, 21, 0.95));
    --placeholder-motif:
      radial-gradient(circle at 50% 50%, rgba(132, 176, 158, 0.14) 0 12%, transparent 40%),
      repeating-linear-gradient(90deg, rgba(171, 214, 196, 0.045) 0 1px, transparent 1px 18px);
  }

  .hitbox {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .preview-wrap {
    grid-column: 2;
    grid-row: 1 / span 5;
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    margin-bottom: 0;
    aspect-ratio: 5 / 4;
    background: rgba(14, 12, 10, 0.75);
    align-self: start;
  }

  .card.mosaic .preview-wrap {
    grid-column: 1;
    grid-row: auto;
    order: 1;
    aspect-ratio: 4 / 3;
    margin: 0;
  }

  .card.mosaic.scroll .preview-wrap {
    aspect-ratio: 4 / 5;
  }

  .card.mosaic.artifact .preview-wrap {
    aspect-ratio: 1 / 1;
  }

  .card.mosaic.fieldlog .preview-wrap {
    aspect-ratio: 16 / 10;
  }

  .card.mosaic.codex .preview-wrap {
    aspect-ratio: 3 / 2;
  }

  .card.mosaic.fragment .preview-wrap {
    aspect-ratio: 6 / 5;
  }

  .card.mosaic.nexus .preview-wrap {
    aspect-ratio: 5 / 4;
  }

  .card.mosaic.signal .preview-wrap {
    aspect-ratio: 5 / 3;
  }

  .card.related .preview-wrap {
    grid-column: 2;
    grid-row: 1 / span 5;
    order: initial;
    aspect-ratio: 5 / 4;
    max-width: none;
  }

  .card.feed .preview-wrap {
    aspect-ratio: 16 / 10;
  }

  .preview-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .preview-fallback,
  .preview-empty {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    text-align: center;
    gap: 0.25rem;
    color: var(--placeholder-label);
    background: var(--placeholder-surface);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .preview-fallback::before,
  .preview-empty::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--placeholder-motif);
    opacity: 0.82;
    pointer-events: none;
  }

  .preview-fallback::after,
  .preview-empty::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 50%, transparent 38%, rgba(14, 12, 10, 0.18) 100%),
      linear-gradient(180deg, rgba(244, 240, 232, 0.06), rgba(14, 12, 10, 0.4));
    pointer-events: none;
  }

  .preview-fallback span,
  .preview-empty span {
    position: relative;
    z-index: 1;
    font-family: var(--font-ui);
    font-size: 0.67rem;
    letter-spacing: var(--ls-ui-wide);
    text-transform: uppercase;
    font-weight: 700;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.5);
  }

  .preview-fallback small {
    position: relative;
    z-index: 1;
    font-family: var(--font-ui);
    font-size: 0.62rem;
    letter-spacing: var(--ls-ui);
  }

  .meta {
    grid-column: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem 0.62rem;
    align-items: center;
    margin-bottom: 0.72rem;
  }

  .card.feed .meta {
    margin-bottom: 0.86rem;
  }

  .card.mosaic .meta {
    order: 2;
    margin: 0.1rem 0 0;
    gap: 0.38rem;
  }

  .card.related .meta {
    grid-column: 1;
    margin-top: 0;
  }

  .date,
  .score {
    font-family: var(--font-ui);
    font-size: 10px;
    color: var(--mid);
    letter-spacing: var(--ls-ui);
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .score {
    color: #d8a861;
  }

  .card.mosaic .date,
  .card.mosaic .score {
    font-size: 10px;
  }

  .title {
    grid-column: 1;
    margin: 0;
    color: var(--star);
    font-size: clamp(2rem, 3.25vw, 2.95rem);
    line-height: 1.18;
    font-style: normal;
    font-weight: 600;
    letter-spacing: var(--ls-title);
    text-wrap: balance;
    max-width: 17ch;
  }

  .card.mosaic .title {
    order: 3;
    max-width: 100%;
    font-size: clamp(1.32rem, 1.95vw, 1.88rem);
    line-height: 1.14;
    letter-spacing: -0.006em;
    text-wrap: pretty;
  }

  .author-tease {
    grid-column: 1;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.46rem;
    margin: 1.1rem 0 0;
    padding-top: 0.66rem;
    border-top: none;
    justify-self: start;
    width: fit-content;
    min-width: 0;
  }

  .card.mosaic .author-tease {
    order: 6;
    margin-top: 0.34rem;
    padding-top: 0.52rem;
  }

  .author-tease::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid rgba(166, 139, 101, 0.2);
  }

  .author-thumb {
    width: 1.28rem;
    height: 1.28rem;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(166, 139, 101, 0.26);
    background: rgba(255, 255, 255, 0.03);
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .author-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .author-thumb span {
    font-family: var(--font-ui);
    font-size: 0.5rem;
    letter-spacing: 0.07em;
    color: var(--mid);
  }

  .author-name {
    margin: 0;
    color: var(--mid);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: none;
    line-height: 1.45;
    display: inline-flex;
    gap: 0.35rem;
    align-items: baseline;
    min-width: 0;
    flex-wrap: wrap;
  }

  .author-name .name {
    color: var(--mid);
    white-space: nowrap;
  }

  .author-name .designation {
    color: var(--ghost);
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .card.feed .title {
    max-width: 15ch;
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    line-height: 1.14;
  }

  .card:hover .title {
    color: #f5d8b5;
  }

  .card.related .title {
    grid-column: 1;
    max-width: 15ch;
    font-size: clamp(2.25rem, 4.1vw, 3.45rem);
    line-height: 1.14;
  }

  .excerpt {
    grid-column: 1;
    max-width: 42ch;
    margin: 1.45rem 0 1.7rem;
    color: var(--text-body);
    font-size: 1.2rem;
    line-height: 1.88;
  }

  .card.mosaic .excerpt {
    order: 4;
    max-width: 100%;
    margin: 0.08rem 0 0.06rem;
    font-size: 0.95rem;
    line-height: 1.56;
    color: rgba(232, 226, 212, 0.88);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card.related .excerpt {
    grid-column: 1;
    margin-top: 1.35rem;
    margin-bottom: 1.2rem;
    max-width: 38ch;
    font-size: 1.16rem;
    line-height: 1.86;
  }

  .card.feed .excerpt {
    margin: 1.14rem 0 1.02rem;
    max-width: 38ch;
    line-height: 1.78;
  }

  .card.nexus .excerpt {
    color: var(--accent-quote-soft);
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.004em;
  }

  .themes {
    grid-column: 1;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.34rem 0.86rem;
  }

  .card.mosaic .themes {
    order: 5;
    gap: 0.36rem 0.42rem;
  }

  .card.related .themes {
    grid-column: 1;
  }

  .themes li {
    font-family: var(--font-ui);
    font-size: 12px;
    border: none;
    padding: 0;
    color: var(--mid);
    background: transparent;
    letter-spacing: var(--ls-ui);
    line-height: 1.3;
  }

  .themes li::before {
    content: '#';
    color: rgba(164, 134, 97, 0.82);
    margin-right: 0.22rem;
  }

  .card.mosaic .themes li {
    font-size: 12px;
  }

  .card.feed .author-name .designation,
  .card.mosaic .author-name .designation {
    display: none;
  }

  @media (max-width: 1040px) {
    .card.feed,
    .card.related {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 1rem;
    }

    .preview-wrap {
      grid-column: 1;
      grid-row: auto;
      order: 2;
      max-width: none;
    }

    .card.feed .preview-wrap,
    .card.related .preview-wrap {
      grid-column: 1;
      grid-row: auto;
      order: 2;
      aspect-ratio: 16 / 9;
      max-width: none;
    }

    .card.related .meta {
      margin-bottom: 0.26rem;
    }
  }

  @media (max-width: 840px) {
    .card {
      grid-template-columns: 1fr;
      row-gap: 1rem;
      padding: 1.9rem 0.45rem 2.2rem;
    }

    .card.related {
      padding-top: 1.65rem;
      padding-bottom: 1.95rem;
    }

    .preview-wrap {
      aspect-ratio: 16 / 9;
    }

    .card.related .preview-wrap {
      aspect-ratio: 16 / 9;
    }

    .card.feed .preview-wrap {
      aspect-ratio: 16 / 9;
    }

    .card.mosaic {
      padding: 0.66rem 0.66rem 0.8rem;
    }

    .card.mosaic .preview-wrap {
      order: 1;
      aspect-ratio: 4 / 3;
    }

    .meta {
      order: 1;
    }

    .author-tease {
      order: 6;
    }

    .title {
      order: 3;
    }

    .excerpt {
      order: 4;
    }

    .themes {
      order: 5;
    }

    .card:not(.mosaic) .meta {
      margin-bottom: 0.36rem;
    }

    .card:not(.mosaic) .title,
    .card.feed .title,
    .card.related .title {
      max-width: 100%;
      font-size: clamp(1.5rem, 7vw, 2.1rem);
      line-height: 1.18;
      text-wrap: pretty;
    }

    .card:not(.mosaic) .excerpt,
    .card.feed .excerpt,
    .card.related .excerpt {
      max-width: 100%;
      margin: 0.62rem 0 0.68rem;
      font-size: 1.02rem;
      line-height: 1.62;
    }

    .card:not(.mosaic) .themes {
      gap: 0.3rem 0.58rem;
    }

    .card:not(.mosaic) .author-tease {
      width: 100%;
      margin-top: 0.56rem;
    }

    .card:not(.mosaic) .author-name {
      display: flex;
      flex-wrap: wrap;
      overflow-wrap: anywhere;
    }

    .card:not(.mosaic) .author-name .name {
      white-space: normal;
    }

    .card.mosaic {
      padding: 0.64rem 0.62rem 0.76rem;
      row-gap: 0.56rem;
    }

    .card.mosaic .title {
      font-size: clamp(1.08rem, 4.8vw, 1.38rem);
    }

    .card.mosaic .excerpt {
      -webkit-line-clamp: 4;
    }
  }

  @media (max-width: 560px) {
    .card {
      row-gap: 0.82rem;
      padding: 1.55rem 0 1.9rem;
    }

    .preview-wrap,
    .card.related .preview-wrap {
      aspect-ratio: 4 / 3;
    }

    .card:not(.mosaic) .title {
      font-size: clamp(1.34rem, 8.2vw, 1.8rem);
    }

    .card:not(.mosaic) .excerpt {
      font-size: 0.96rem;
      line-height: 1.56;
    }

    .themes li {
      font-size: 12px;
    }

    .author-name {
      font-size: 8px;
    }

    .card.mosaic .excerpt {
      font-size: 0.9rem;
      line-height: 1.5;
    }
  }
</style>
