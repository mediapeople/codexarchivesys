---
import TypeBadge from './TypeBadge.astro';
import type { ArchiveEntry } from '../lib/archive';
import { formatMediaLabel, getMediaItems, pickPrimaryMedia, withMediaVersion } from '../lib/media';
import { formatDisplayTitle } from '../lib/headline';
import { getAuthorInitials, getPrimaryAuthor } from '../lib/author';
import { getLoremapAtlasRender } from '../lib/loremap';
import { getImageAssetMetadata, getPublicAssetVersion } from '../lib/mediaAsset';
import { formatArchiveDate } from '../lib/timeline';

interface Props {
  entry: ArchiveEntry;
  href?: string;
  relationScore?: number;
  variant?: 'feed' | 'related' | 'mosaic';
  eyebrow?: string;
}

type FragmentStageToken =
  | {
      kind: 'line';
      text: string;
      speaker?: string;
      body?: string;
    }
  | {
      kind: 'gap';
      variant: 'standard' | 'turn';
    };

const {
  entry,
  href = `/objects/${entry.data.id}`,
  relationScore,
  variant = 'feed',
  eyebrow,
} = Astro.props;
const mediaItems = getMediaItems(entry);
const primaryMedia = pickPrimaryMedia(mediaItems);
const displayTitle = formatDisplayTitle(entry.data.title);
const primaryAuthor = getPrimaryAuthor(entry);
const authorInitials = getAuthorInitials(primaryAuthor.name);
const authorDesignation = primaryAuthor.designation || primaryAuthor.role || 'Archive operator';
const isFragment = entry.collection === 'fragment';

function normalizeForCompare(value: string): string {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
}

function formatSlugLabel(value: string): string {
  return value
    .split(/[-_]+/)
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function stripMarkdownFormatting(value: string): string {
  return value
    .replace(/\r\n/g, '\n')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\*([^*]+)\*/g, '$1')
    .replace(/^>\s?/gm, '')
    .replace(/^[-*+]\s+/gm, '')
    .trim();
}

function parseSpeakerLine(line: string) {
  const match = line.match(/^([A-Z][A-Za-z0-9 /&-]{1,24}):\s*(.+)$/);
  if (!match) {
    return null;
  }

  return {
    speaker: match[1],
    body: match[2],
  };
}

function getSpeakerTone(speaker: string) {
  const normalized = speaker.trim().toLowerCase();
  if (normalized === 'operator') {
    return 'operator';
  }
  if (normalized === 'system') {
    return 'system';
  }
  return 'other';
}

function getSpeakerPreviewLabel(speaker: string) {
  const tone = getSpeakerTone(speaker);
  if (tone === 'operator') {
    return 'Prompt';
  }
  if (tone === 'system') {
    return 'Return';
  }
  return speaker;
}

function getImagePreviewFrameStyle(
  metadata: { width: number; height: number } | null,
  imageCount: number,
  variant: 'feed' | 'related' | 'mosaic'
): string | undefined {
  if (!metadata?.width || !metadata?.height) {
    return undefined;
  }

  const padInline = variant === 'related' ? 20 : 18;
  const padTop = 18;
  const padBottom = imageCount > 1 ? 40 : 32;
  const frameWidth = metadata.width + padInline * 2;
  const frameHeight = metadata.height + padTop + padBottom;

  return [
    `--image-preview-frame-ratio: ${frameWidth} / ${frameHeight}`,
    `--image-preview-object-ratio: ${metadata.width} / ${metadata.height}`,
    `--image-preview-pad-inline: ${padInline}px`,
    `--image-preview-pad-top: ${padTop}px`,
    `--image-preview-pad-bottom: ${padBottom}px`,
  ].join('; ');
}

function getFragmentStageContent(body: string, fallback: string, maxLines: number): FragmentStageToken[] {
  const source = stripMarkdownFormatting(body || fallback);
  const normalizedLines = source
    .split('\n')
    .map((line) => line.trim())
    .reduce<string[]>((lines, line) => {
      if (!line) {
        if (lines.length > 0 && lines[lines.length - 1] !== '') {
          lines.push('');
        }
        return lines;
      }

      lines.push(line);
      return lines;
    }, [])
    .filter((line, index, lines) => !(line === '' && index === lines.length - 1));

  const truncatedLines = normalizedLines.length <= maxLines
    ? normalizedLines
    : (() => {
        const truncated = normalizedLines.slice(0, maxLines);
        const lastLine = truncated[maxLines - 1];
        truncated[maxLines - 1] = lastLine ? `${lastLine.replace(/[.?!,:;]+$/, '')}...` : '...';
        return truncated;
      })();

  return truncatedLines.map((line, index, lines) => {
    if (!line) {
      const previous = lines[index - 1] || '';
      const next = lines[index + 1] || '';
      return {
        kind: 'gap',
        variant: parseSpeakerLine(previous) || parseSpeakerLine(next) ? 'turn' : 'standard',
      };
    }

    const speakerLine = parseSpeakerLine(line);
    if (!speakerLine) {
      return {
        kind: 'line',
        text: line,
      };
    }

    return {
      kind: 'line',
      text: line,
      speaker: speakerLine.speaker,
      body: speakerLine.body,
    };
  });
}

const fallbackSummary = (entry.data as Record<string, unknown>).themeStatement;
const rawSummary =
  entry.data.excerpt ||
  (typeof fallbackSummary === 'string' ? fallbackSummary : '');
const summaryText = normalizeForCompare(rawSummary) ? rawSummary : '';
const fragmentStageLines = isFragment && variant !== 'related'
  ? getFragmentStageContent(entry.body, summaryText, variant === 'mosaic' ? 4 : 6)
  : [];
const lengthClass = isFragment && typeof (entry.data as Record<string, unknown>).lengthClass === 'string'
  ? String((entry.data as Record<string, unknown>).lengthClass)
  : '';
const showFragmentStage = fragmentStageLines.length > 0;
const isFragmentInterlude = showFragmentStage && variant === 'feed';
const showFragmentStageFooter = showFragmentStage && !isFragmentInterlude;
const showExcerpt = Boolean(summaryText) && !showFragmentStage;
const showThemes = entry.data.themes.length > 0 && variant !== 'mosaic' && !showFragmentStage;
const showAuthorTease = !showFragmentStage;
const hasImagePreview = !showFragmentStage && primaryMedia?.kind === 'image';
const primaryMediaMeta = hasImagePreview ? await getImageAssetMetadata(primaryMedia.src) : null;
const imagePreviewItems = hasImagePreview
  ? [
      primaryMedia,
      ...mediaItems.filter(
        (item) => item.kind === 'image' && (item.src !== primaryMedia?.src || item.role !== primaryMedia?.role)
      ),
    ]
  : [];
const previewMediaVersionEntries = hasImagePreview
  ? await Promise.all(imagePreviewItems.map(async (item) => [item.src, await getPublicAssetVersion(item.src)] as const))
  : [];
const previewMediaVersionBySrc = new Map(previewMediaVersionEntries);
const getPreviewMediaSrc = (src: string) => withMediaVersion(src, previewMediaVersionBySrc.get(src) ?? undefined);
const hasIndependentPreviewAction = hasImagePreview && (variant === 'feed' || variant === 'related');
const useCenteredCopyStack = !showFragmentStage && (variant === 'feed' || variant === 'related');
const primaryMediaCaption = primaryMedia?.caption || '';
const primaryMediaSrc = primaryMedia ? getPreviewMediaSrc(primaryMedia.src) : '';
const previewImageCount = imagePreviewItems.length;
const previewFrameStyle = hasImagePreview
  ? getImagePreviewFrameStyle(primaryMediaMeta, previewImageCount, variant)
  : undefined;
const previewGalleryPayload = hasIndependentPreviewAction
  ? JSON.stringify(
      imagePreviewItems.map((item) => ({
        src: getPreviewMediaSrc(item.src),
        alt: item.alt || `${entry.data.title} media preview`,
        caption: item.caption || '',
      }))
    )
  : undefined;
const searchCorpus = [displayTitle, summaryText, ...entry.data.themes, ...entry.data.constellations]
  .join(' ')
  .toLowerCase();

const readableDate = formatArchiveDate(entry.data.date);
const isLoremap = entry.collection === 'loremap';
const loremapAtlas = getLoremapAtlasRender(entry.data as Record<string, unknown>, displayTitle, 'card');
const showLoremapPreview = isLoremap && !showFragmentStage && !primaryMedia;
const useLoremapMinimalThumb = showLoremapPreview && (variant === 'feed' || variant === 'related');
const showLoremapGeo = loremapAtlas.geo.toLowerCase() !== 'coordinates pending';
const artifactType = entry.collection === 'artifact' && typeof (entry.data as Record<string, unknown>).artifactType === 'string'
  ? String((entry.data as Record<string, unknown>).artifactType).trim()
  : '';
const artifactSource = entry.collection === 'artifact' && typeof (entry.data as Record<string, unknown>).source === 'string'
  ? String((entry.data as Record<string, unknown>).source).trim()
  : '';
const showHtmlArtifactPreview =
  entry.collection === 'artifact' && !primaryMedia && /^\/.+\.html$/i.test(artifactSource);
const artifactSourceName = showHtmlArtifactPreview
  ? artifactSource.split('/').filter(Boolean).pop()?.replace(/\.html$/i, '') || ''
  : '';
const artifactSourceLabel = artifactSourceName ? formatSlugLabel(artifactSourceName) : displayTitle;
const artifactPreviewLead = artifactType || 'browser-native artifact';
---

<article
  class={`card ${entry.collection} ${variant}`}
  data-type={entry.collection}
  data-themes={entry.data.themes.join('|').toLowerCase()}
  data-search={searchCorpus}
>
  {!showFragmentStage && <a class="hitbox" href={href} aria-label={`Open ${entry.data.title}`}></a>}
  <div
    class={`preview-wrap page-plate ${showFragmentStage ? 'fragment-stage' : ''} ${hasImagePreview ? 'has-image-preview' : ''} ${hasIndependentPreviewAction ? 'card-image-trigger' : ''}`}
    data-media-frame={hasImagePreview ? 'card-preview' : undefined}
    data-media-shape={primaryMediaMeta?.shape}
    data-card-image-trigger={hasIndependentPreviewAction ? 'true' : undefined}
    data-card-lightbox-src={hasIndependentPreviewAction ? primaryMediaSrc : undefined}
    data-card-lightbox-alt={hasIndependentPreviewAction ? (primaryMedia?.alt || `${entry.data.title} media preview`) : undefined}
    data-card-lightbox-caption={hasIndependentPreviewAction ? primaryMediaCaption : undefined}
    data-card-lightbox-images={previewGalleryPayload}
    data-card-lightbox-href={hasIndependentPreviewAction ? href : undefined}
    data-card-lightbox-title={hasIndependentPreviewAction ? entry.data.title : undefined}
    tabindex={hasIndependentPreviewAction ? 0 : undefined}
    role={hasIndependentPreviewAction ? 'button' : undefined}
    aria-label={hasIndependentPreviewAction ? `Expand ${previewImageCount > 1 ? `${previewImageCount}-image gallery` : 'image'} from ${entry.data.title}` : undefined}
    style={previewFrameStyle}
  >
    {showFragmentStage ? (
      <>
        <span class="fragment-stage-mark" aria-hidden="true">"</span>
        <div class="fragment-piece" aria-label="Fragment text preview">
          {fragmentStageLines.map((token) => (
            token.kind === 'line' ? (
              <span class={`fragment-line ${token.speaker ? `fragment-line--speaker fragment-line--${getSpeakerTone(token.speaker)}` : ''}`}>
                {token.speaker ? (
                  <>
                    <span class={`fragment-speaker fragment-speaker--${getSpeakerTone(token.speaker)}`}>
                      {getSpeakerPreviewLabel(token.speaker)}
                    </span>
                    <span class="fragment-utterance">{token.body}</span>
                  </>
                ) : (
                  token.text
                )}
              </span>
            ) : (
              <span class={`fragment-gap fragment-gap--${token.variant}`} aria-hidden="true"></span>
            )
          ))}
        </div>
        {showFragmentStageFooter && (
          <div class="fragment-stage-footer">
            <span>{lengthClass ? `${lengthClass} fragment` : 'Fragment'}</span>
            {entry.data.related.length > 0 && <span>{entry.data.related.length} linked</span>}
          </div>
        )}
      </>
    ) : primaryMedia?.kind === 'image' ? (
      <img
        class="preview-image"
        src={primaryMediaSrc}
        alt={primaryMedia.alt || `${entry.data.title} media preview`}
        width={primaryMediaMeta?.width}
        height={primaryMediaMeta?.height}
        loading="lazy"
        decoding="async"
      />
    ) : primaryMedia ? (
      <div class="preview-fallback">
        <span>{primaryMedia.kind}</span>
        <small>{formatMediaLabel(primaryMedia)}</small>
      </div>
    ) : showLoremapPreview ? (
      <div class={`preview-loremap ${useLoremapMinimalThumb ? 'preview-loremap--minimal' : ''}`} aria-hidden="true">
        {!useLoremapMinimalThumb && (
          <div class="preview-loremap-head">
            <span>Field Position</span>
            <small>{loremapAtlas.hudLocation}</small>
          </div>
        )}
        <svg
          class="preview-loremap-map"
          viewBox="0 0 320 220"
          role="presentation"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect x="16" y="16" width="288" height="188" fill="none" stroke="rgba(198,220,236,0.72)" stroke-width="1" />
          <rect x="30" y="30" width="260" height="160" fill="none" stroke="rgba(101,127,146,0.72)" stroke-width="1" />
          {loremapAtlas.terrainPoints.map((points) => (
            <polyline
              points={points}
              fill="none"
              stroke="rgba(101,127,146,0.46)"
              stroke-width="1"
            />
          ))}
          <path
            d={`M${loremapAtlas.routePoints.split(' ').join(' L').replace(/^/, '')}`}
            fill="none"
            stroke="#d8e6ef"
            stroke-width="1.8"
            stroke-linecap="round"
          />
          <g transform={`translate(${loremapAtlas.markerX} ${loremapAtlas.markerY})`}>
            <line x1="-11" y1="0" x2="11" y2="0" stroke="#de6d2f" stroke-width="1.2" />
            <line x1="0" y1="-11" x2="0" y2="11" stroke="#de6d2f" stroke-width="1.2" />
            <circle cx="0" cy="0" r="4.2" fill="none" stroke="#de6d2f" stroke-width="1.4" />
          </g>
          <text x="38" y="50" font-family="IBM Plex Mono, monospace" font-size="10" fill="#8fb0c7">{loremapAtlas.hudTerrain}</text>
          {showLoremapGeo && (
            <text x="216" y="50" font-family="IBM Plex Mono, monospace" font-size="9" fill="#8fb0c7">{loremapAtlas.hudGeo}</text>
          )}
          {!useLoremapMinimalThumb && (
            <text x="38" y="178" font-family="IBM Plex Mono, monospace" font-size="11" fill="#d8e6ef">LOREMAP</text>
          )}
          <text x={useLoremapMinimalThumb ? '38' : '126'} y="178" font-family="IBM Plex Mono, monospace" font-size="11" fill="#d8e6ef">
            {loremapAtlas.hudLocation}
          </text>
          <text x="38" y="24" font-family="IBM Plex Mono, monospace" font-size="11" fill="#d8e6ef">N</text>
        </svg>
        {!useLoremapMinimalThumb && (
          <div class="preview-loremap-foot">
            <span>{loremapAtlas.location || displayTitle}</span>
            <strong>{loremapAtlas.terrain || 'terrain pending'}</strong>
          </div>
        )}
      </div>
    ) : showHtmlArtifactPreview ? (
      <div class="preview-html-surface" aria-hidden="true">
        <div class="preview-html-surface-chrome">
          <span></span>
          <span></span>
          <span></span>
          <p>HTML surface</p>
        </div>
        <div class="preview-html-surface-field">
          <p class="preview-html-surface-kicker">Elevated scroll</p>
          <strong class="preview-html-surface-title">{artifactPreviewLead}</strong>
          <span class="preview-html-surface-name">{artifactSourceLabel}</span>
        </div>
        <div class="preview-html-surface-measure">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    ) : (
      <div class={`preview-empty ${entry.collection}`}>
        <span>{entry.collection}</span>
      </div>
    )}
    {hasIndependentPreviewAction && previewImageCount > 1 && (
      <span class="preview-gallery-count" aria-hidden="true">1/{previewImageCount}</span>
    )}
    {hasIndependentPreviewAction && <span class="preview-expand-mark" aria-hidden="true">+</span>}
  </div>
  {useCenteredCopyStack ? (
    <div class="copy-stack">
      <header class="meta">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <TypeBadge type={entry.collection} />
        {variant !== 'mosaic' && <span class="date">{readableDate}</span>}
        {variant === 'related' && relationScore !== undefined && <span class="score">{relationScore} signals</span>}
      </header>
      <h3 class="title">{displayTitle}</h3>
      {showExcerpt && <p class="excerpt">{summaryText}</p>}
      {showThemes && (
        <ul class="themes">
          {entry.data.themes.slice(0, 3).map((theme) => (
            <li>{theme}</li>
          ))}
        </ul>
      )}
      {showAuthorTease && (
        <div class="author-tease">
          <div class="author-thumb" aria-hidden="true">
            {primaryAuthor.avatar ? (
              <img src={primaryAuthor.avatar} alt="" loading="lazy" decoding="async" />
            ) : (
              <span>{authorInitials}</span>
            )}
          </div>
          <p class="author-name">
            <span class="name">{primaryAuthor.name}</span>
            <span class="designation">, {authorDesignation}</span>
          </p>
        </div>
      )}
    </div>
  ) : (
    <>
      {!isFragmentInterlude && (
        <header class="meta">
          {eyebrow && <span class="eyebrow">{eyebrow}</span>}
          <TypeBadge type={entry.collection} />
          {variant !== 'mosaic' && <span class="date">{readableDate}</span>}
          {variant === 'related' && relationScore !== undefined && <span class="score">{relationScore} signals</span>}
        </header>
      )}
      <h3 class={`title ${isFragmentInterlude ? 'fragment-title-hidden' : ''}`}>{displayTitle}</h3>
      {showFragmentStage && (
        <p class="fragment-meta-link-row">
          {isFragmentInterlude && <span class="fragment-foot-label">Fragment</span>}
          <a class={`fragment-meta-link ${isFragmentInterlude ? 'fragment-meta-link--interlude' : ''}`} href={href}>
            {isFragmentInterlude ? 'Inspect context' : 'View metadata'}
          </a>
        </p>
      )}
      {showExcerpt && <p class="excerpt">{summaryText}</p>}
      {showThemes && (
        <ul class="themes">
          {entry.data.themes.slice(0, 3).map((theme) => (
            <li>{theme}</li>
          ))}
        </ul>
      )}
      {showAuthorTease && (
        <div class="author-tease">
          <div class="author-thumb" aria-hidden="true">
            {primaryAuthor.avatar ? (
              <img src={primaryAuthor.avatar} alt="" loading="lazy" decoding="async" />
            ) : (
              <span>{authorInitials}</span>
            )}
          </div>
          <p class="author-name">
            <span class="name">{primaryAuthor.name}</span>
            <span class="designation">, {authorDesignation}</span>
          </p>
        </div>
      )}
    </>
  )}
</article>

<style>
  .card {
    --type-accent: var(--ghost);
    --card-plate-shadow: 0 16px 38px rgba(0, 0, 0, 0.16);
    --card-plate-surface: linear-gradient(180deg, rgba(31, 24, 18, 0.94), rgba(15, 12, 10, 0.97));
    --placeholder-surface:
      linear-gradient(150deg, rgba(60, 53, 46, 0.24), rgba(18, 16, 14, 0.9));
    --placeholder-motif: radial-gradient(circle at center, rgba(255, 255, 255, 0.04), transparent 62%);
    --placeholder-label: rgba(231, 222, 209, 0.76);
    position: relative;
    display: grid;
    column-gap: 3.2rem;
    border: none;
    border-radius: 0;
    padding: 3.2rem clamp(0.7rem, 1.3vw, 1.2rem) 3.8rem;
    background: transparent;
    transition: transform 120ms ease;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-1px);
  }

  .card.feed.fragment:hover,
  .card.mosaic.fragment:hover {
    transform: none;
  }

  .card.feed {
    --specimen-tilt: -0.9deg;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 42%);
    padding-left: 0;
    padding-right: 0;
    padding-top: 1.9rem;
    padding-bottom: 2.2rem;
  }

  .card.feed:nth-of-type(even),
  .card.related:nth-of-type(even) {
    --specimen-tilt: 0.75deg;
  }

  .card.feed.fragment {
    grid-template-columns: 1fr;
    row-gap: 0;
    justify-items: center;
    margin: 1.1rem 0 1.35rem;
    padding-top: 1.1rem;
    padding-bottom: 1.35rem;
    background: transparent;
    box-shadow: none;
  }

  .card.related {
    --specimen-tilt: -0.7deg;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 40%);
    column-gap: 4.8rem;
    row-gap: 1.2rem;
    padding-top: 1.8rem;
    padding-bottom: 2rem;
  }

  .card.mosaic {
    grid-template-columns: 1fr;
    row-gap: 0.72rem;
    column-gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 2px;
    padding: 0.7rem 0.75rem 0.86rem;
    background:
      linear-gradient(170deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0)),
      rgba(14, 12, 10, 0.6);
  }

  .card.scroll {
    --type-accent: rgba(196, 98, 58, 0.85);
    --placeholder-surface:
      linear-gradient(152deg, rgba(196, 98, 58, 0.16), rgba(20, 18, 16, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(180deg, rgba(244, 240, 232, 0.055) 0 1px, transparent 1px 14px),
      linear-gradient(90deg, rgba(196, 98, 58, 0.08), transparent 62%);
  }

  .card.loremap {
    --type-accent: rgba(112, 150, 178, 0.88);
    --placeholder-surface:
      linear-gradient(150deg, rgba(98, 132, 160, 0.2), rgba(16, 19, 24, 0.94));
    --placeholder-motif:
      repeating-linear-gradient(90deg, rgba(194, 223, 237, 0.04) 0 1px, transparent 1px 18px),
      repeating-linear-gradient(0deg, rgba(194, 223, 237, 0.03) 0 1px, transparent 1px 18px),
      linear-gradient(150deg, rgba(112, 150, 178, 0.12), transparent 62%);
  }

  .card.artifact {
    --type-accent: rgba(201, 150, 58, 0.88);
    --placeholder-surface:
      linear-gradient(150deg, rgba(201, 150, 58, 0.17), rgba(22, 19, 16, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(45deg, rgba(233, 201, 140, 0.05) 0 1px, transparent 1px 12px),
      repeating-linear-gradient(-45deg, rgba(233, 201, 140, 0.035) 0 1px, transparent 1px 14px);
  }

  .card.fieldlog {
    --type-accent: rgba(138, 132, 128, 0.8);
    --placeholder-surface:
      linear-gradient(150deg, rgba(138, 132, 128, 0.18), rgba(20, 18, 16, 0.9));
    --placeholder-motif:
      repeating-linear-gradient(0deg, rgba(232, 226, 212, 0.045) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(90deg, rgba(232, 226, 212, 0.04) 0 1px, transparent 1px 16px);
  }

  .card.codex {
    --type-accent: rgba(201, 150, 58, 0.7);
    --placeholder-surface:
      linear-gradient(150deg, rgba(184, 153, 102, 0.15), rgba(19, 17, 15, 0.92));
    --placeholder-motif:
      repeating-linear-gradient(90deg, rgba(229, 196, 134, 0.045) 0 2px, transparent 2px 28px),
      linear-gradient(180deg, rgba(233, 201, 140, 0.045), transparent 60%);
  }

  .card.fragment {
    --type-accent: rgba(92, 84, 80, 0.86);
    --placeholder-surface:
      linear-gradient(150deg, rgba(92, 84, 80, 0.22), rgba(20, 18, 16, 0.9));
    --placeholder-motif:
      repeating-linear-gradient(132deg, rgba(215, 196, 167, 0.042) 0 1px, transparent 1px 13px),
      repeating-linear-gradient(168deg, rgba(215, 196, 167, 0.03) 0 1px, transparent 1px 21px);
  }

  .card.nexus {
    --type-accent: var(--rust);
    --placeholder-surface:
      linear-gradient(150deg, rgba(196, 98, 58, 0.2), rgba(24, 18, 16, 0.94));
    --placeholder-motif:
