---
interface FieldlogSpec {
  label: string;
  value: string;
  note?: string;
}

interface PlateSpec extends FieldlogSpec {
  key: string;
}

interface Props {
  title: string;
  specs: FieldlogSpec[];
  excerpt?: string;
  location?: string;
  dateLabel?: string;
}

const { title, specs = [], excerpt = '', location = '', dateLabel = '' } = Astro.props as Props;

function normalizeLabel(label: string): string {
  return label.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');
}

const normalizedSpecs: PlateSpec[] = specs.map((spec) => ({
  ...spec,
  key: normalizeLabel(spec.label),
}));

const specByKey = new Map(normalizedSpecs.map((spec) => [spec.key, spec] as const));
const leadSpec = specByKey.get('beer') ?? normalizedSpecs[0] ?? null;
const styleSpec = specByKey.get('style') ?? null;
const orderedCardKeys = ['brewery', 'site', 'hops', 'milestone', 'glass'];
const usedKeys = new Set<string>();

if (leadSpec) {
  usedKeys.add(leadSpec.key);
}

if (styleSpec) {
  usedKeys.add(styleSpec.key);
}

const primaryCards = orderedCardKeys
  .map((key) => specByKey.get(key))
  .filter((spec): spec is PlateSpec => Boolean(spec))
  .filter((spec) => !usedKeys.has(spec.key));

for (const spec of primaryCards) {
  usedKeys.add(spec.key);
}

const supportingCards = normalizedSpecs.filter((spec) => !usedKeys.has(spec.key));
const plateCards = [...primaryCards, ...supportingCards];
const heroSummary = styleSpec?.note || leadSpec?.note || excerpt;
const signalRows = normalizedSpecs.filter(
  (spec) => Boolean(spec.note) && spec.key !== leadSpec?.key && spec.key !== styleSpec?.key
);

const metaItems = [
  location ? { label: 'Location', value: location } : null,
  dateLabel ? { label: 'Logged', value: dateLabel } : null,
].filter((item): item is { label: string; value: string } => Boolean(item));
---

<section class="fieldlog-plate-shell page-plate" aria-labelledby="fieldlog-plate-title">
  <header class="fieldlog-plate-header">
    <div class="fieldlog-plate-heading">
      <p class="fieldlog-plate-kicker">Structured Readout</p>
      <p class="fieldlog-plate-ruler" aria-hidden="true">Plate // calibrated tasting surface</p>
    </div>
    <div class="fieldlog-plate-stamp page-plate">
      <span>Fieldlog Plate</span>
      <strong>{styleSpec?.value || leadSpec?.label || 'Specimen'}</strong>
    </div>
  </header>

  <div class="fieldlog-plate-grid">
    <section class="fieldlog-plate-hero page-plate">
      <p class="fieldlog-plate-code">{leadSpec?.label || 'Field Plate'}</p>
      <h2 id="fieldlog-plate-title">{leadSpec?.value || title}</h2>
      {styleSpec?.value && <p class="fieldlog-plate-style">{styleSpec.value}</p>}
      {heroSummary && <p class="fieldlog-plate-summary">{heroSummary}</p>}

      {metaItems.length > 0 && (
        <ul class="fieldlog-plate-meta" aria-label="Plate metadata">
          {metaItems.map((item) => (
            <li class="page-plate">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </li>
          ))}
        </ul>
      )}
    </section>

    {plateCards.length > 0 && (
      <section class="fieldlog-plate-rack" aria-label="Structured field details">
        {plateCards.map((spec, index) => (
          <article class={`fieldlog-plate-card page-plate ${index === 0 ? 'fieldlog-plate-card--emphasis' : ''}`}>
            <p class="fieldlog-plate-card-label">{spec.label}</p>
            <strong>{spec.value}</strong>
            {spec.note && <span>{spec.note}</span>}
          </article>
        ))}
      </section>
    )}
  </div>

  {signalRows.length > 0 && (
    <section class="fieldlog-plate-signals" aria-label="Signal notes">
      <p class="fieldlog-plate-signals-label">Signal Notes</p>
      <div class="fieldlog-plate-signals-grid">
        {signalRows.map((spec) => (
          <article class="fieldlog-plate-signal page-plate">
            <p>{spec.label}</p>
            <strong>{spec.note}</strong>
          </article>
        ))}
      </div>
    </section>
  )}
</section>

<style>
  .fieldlog-plate-shell {
    --plate-line: rgba(198, 146, 88, 0.32);
    --plate-line-soft: rgba(198, 146, 88, 0.16);
    --plate-highlight: rgba(255, 244, 228, 0.08);
    --plate-copy: rgba(243, 238, 228, 0.94);
    --plate-muted: rgba(225, 207, 180, 0.72);
    --plate-label: rgba(240, 214, 174, 0.84);
    --plate-amber: rgba(224, 163, 86, 0.92);
    --plate-border: rgba(198, 146, 88, 0.28);
    --plate-shadow: 0 22px 48px rgba(0, 0, 0, 0.24);
    --plate-surface: linear-gradient(180deg, rgba(15, 18, 24, 0.98), rgba(11, 14, 20, 0.99));
    --plate-tint: rgba(229, 154, 69, 0.12);
    --plate-tint-secondary: rgba(54, 91, 142, 0.1);
    position: relative;
    margin: 2.5rem 0 2.35rem;
    max-width: min(1160px, 100%);
    padding: clamp(1.18rem, 2.05vw, 1.78rem);
  }

  .fieldlog-plate-shell::before,
  .fieldlog-plate-shell::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .fieldlog-plate-shell::before {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.04), transparent 18%),
      linear-gradient(180deg, rgba(243, 228, 203, 0.03), transparent 42%);
    opacity: 0.52;
  }

  .fieldlog-plate-shell::after {
    inset: 8px;
    border: 1px solid rgba(236, 193, 132, 0.1);
    border-radius: 0;
  }

  .fieldlog-plate-header,
  .fieldlog-plate-grid,
  .fieldlog-plate-signals {
    position: relative;
    z-index: 1;
  }

  .fieldlog-plate-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem 1.5rem;
    margin-bottom: 1.3rem;
  }

  .fieldlog-plate-kicker,
  .fieldlog-plate-ruler,
  .fieldlog-plate-code,
  .fieldlog-plate-card-label,
  .fieldlog-plate-signals-label,
  .fieldlog-plate-signal p,
  .fieldlog-plate-meta span,
  .fieldlog-plate-stamp span {
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: var(--ls-ui-wide);
  }

  .fieldlog-plate-kicker {
    margin: 0 0 0.28rem;
    color: var(--plate-label);
    font-size: 10px;
  }

  .fieldlog-plate-ruler {
    margin: 0;
    color: rgba(152, 179, 209, 0.66);
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .fieldlog-plate-stamp {
    --plate-border: rgba(204, 155, 94, 0.18);
    --plate-shadow: 0 14px 28px rgba(0, 0, 0, 0.16);
    --plate-surface: linear-gradient(180deg, rgba(13, 17, 25, 0.76), rgba(10, 12, 18, 0.82));
    --plate-tint: rgba(224, 163, 86, 0.08);
    --plate-tint-secondary: rgba(152, 179, 209, 0.05);
    min-width: 14.5rem;
    padding: 0.9rem 1.04rem 0.96rem;
    text-align: right;
  }

  .fieldlog-plate-stamp span {
    display: block;
    margin: 0 0 0.28rem;
    color: rgba(226, 201, 164, 0.72);
    font-size: 10px;
  }

  .fieldlog-plate-stamp strong {
    color: var(--plate-copy);
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.1;
    font-weight: 600;
  }

  .fieldlog-plate-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(360px, 0.94fr);
    gap: 1.15rem 1.25rem;
    align-items: stretch;
  }

  .fieldlog-plate-hero,
  .fieldlog-plate-card,
  .fieldlog-plate-signal {
    --plate-border: var(--plate-line-soft);
    --plate-shadow: 0 14px 30px rgba(0, 0, 0, 0.14);
    --plate-surface: linear-gradient(180deg, rgba(12, 16, 24, 0.54), rgba(9, 12, 18, 0.62));
    --plate-tint: rgba(224, 163, 86, 0.05);
    --plate-tint-secondary: rgba(152, 179, 209, 0.04);
  }

  .fieldlog-plate-hero {
    padding: clamp(1.3rem, 2.2vw, 1.92rem);
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.12rem;
  }

  .fieldlog-plate-code {
    margin: 0;
    color: rgba(152, 179, 209, 0.82);
    font-size: 10px;
  }

  .fieldlog-plate-hero h2 {
    margin: 0;
    max-width: 10ch;
    color: var(--plate-copy);
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 4.6vw, 3.75rem);
    line-height: 0.94;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  .fieldlog-plate-style {
    width: fit-content;
    margin: 0;
    padding: 0.36rem 0.7rem 0.38rem;
    border: 1px solid rgba(224, 163, 86, 0.32);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(245, 188, 116, 0.16), rgba(245, 188, 116, 0)),
      rgba(59, 40, 20, 0.4);
    color: rgba(250, 235, 210, 0.96);
    font-family: var(--font-ui);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .fieldlog-plate-summary {
    margin: 0;
    max-width: 40ch;
    color: var(--plate-muted);
    font-size: 1.02rem;
    line-height: 1.66;
    text-wrap: balance;
  }

  .fieldlog-plate-meta {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.82rem;
  }

  .fieldlog-plate-meta li {
    --plate-border: rgba(216, 177, 125, 0.16);
    --plate-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
    --plate-surface: linear-gradient(180deg, rgba(9, 13, 19, 0.68), rgba(8, 12, 18, 0.76));
    --plate-tint: rgba(224, 163, 86, 0.04);
    --plate-tint-secondary: rgba(152, 179, 209, 0.03);
    min-width: 12rem;
    padding: 0.84rem 0.94rem 0.9rem;
  }

  .fieldlog-plate-meta span {
    display: block;
    margin: 0 0 0.3rem;
    color: rgba(165, 189, 214, 0.72);
    font-size: 9px;
  }

  .fieldlog-plate-meta strong {
    display: block;
    color: rgba(247, 239, 225, 0.94);
    font-family: var(--font-ui);
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .fieldlog-plate-rack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .fieldlog-plate-card {
    min-height: 12rem;
    padding: 1.14rem 1.14rem 1.22rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.7rem;
  }

  .fieldlog-plate-card--emphasis {
    --plate-tint: rgba(227, 161, 79, 0.1);
    --plate-tint-secondary: rgba(152, 179, 209, 0.05);
  }

  .fieldlog-plate-card-label {
    margin: 0;
    color: var(--plate-label);
    font-size: 10px;
  }

  .fieldlog-plate-card strong {
    display: block;
    color: var(--plate-copy);
    font-size: clamp(1.18rem, 1.8vw, 1.5rem);
    line-height: 1.16;
    font-weight: 600;
    text-wrap: balance;
  }

  .fieldlog-plate-card span {
    display: block;
    color: var(--plate-muted);
    font-size: 0.94rem;
    line-height: 1.56;
    text-wrap: balance;
  }

  .fieldlog-plate-signals {
    margin-top: 1.08rem;
    padding-top: 1.08rem;
    border-top: 1px solid rgba(213, 172, 117, 0.14);
  }

  .fieldlog-plate-signals-label {
    margin: 0 0 0.74rem;
    color: rgba(152, 179, 209, 0.78);
    font-size: 10px;
  }

  .fieldlog-plate-signals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.72rem;
  }

  .fieldlog-plate-signal {
    min-height: 7.4rem;
    padding: 1rem 1.02rem 1.08rem;
  }

  @media (min-width: 1100px) {
    .fieldlog-plate-shell {
      max-width: min(1200px, 100%);
      padding: 1.48rem 1.58rem 1.66rem;
    }

    .fieldlog-plate-grid {
      grid-template-columns: minmax(0, 1.14fr) minmax(420px, 0.86fr);
      gap: 1.3rem 1.45rem;
    }

    .fieldlog-plate-rack {
      gap: 1.06rem;
    }

    .fieldlog-plate-card {
      min-height: 12.6rem;
      padding: 1.2rem 1.22rem 1.3rem;
    }
  }

  .fieldlog-plate-signal p {
    margin: 0 0 0.48rem;
    color: rgba(226, 201, 164, 0.72);
    font-size: 10px;
  }

  .fieldlog-plate-signal strong {
    display: block;
    color: rgba(242, 236, 225, 0.9);
    font-size: 0.98rem;
    line-height: 1.58;
    font-weight: 500;
    text-wrap: balance;
  }

  @media (max-width: 900px) {
    .fieldlog-plate-grid {
      grid-template-columns: 1fr;
    }

    .fieldlog-plate-stamp {
      text-align: left;
      min-width: 0;
    }
  }

  @media (max-width: 680px) {
    .fieldlog-plate-rack {
      grid-template-columns: 1fr;
    }

    .fieldlog-plate-card,
    .fieldlog-plate-signal {
      min-height: 0;
    }
  }

  @media (max-width: 560px) {
    .fieldlog-plate-shell {
      padding: 0.95rem;
      border-radius: 0;
    }

    .fieldlog-plate-header {
      margin-bottom: 0.95rem;
    }

    .fieldlog-plate-hero {
      padding: 1rem;
    }

    .fieldlog-plate-hero h2 {
      max-width: 100%;
      font-size: clamp(2rem, 11vw, 2.7rem);
    }

    .fieldlog-plate-summary {
      font-size: 0.98rem;
    }

    .fieldlog-plate-meta {
      display: grid;
      grid-template-columns: 1fr;
    }

    .fieldlog-plate-meta li {
      min-width: 0;
    }
  }
</style>
