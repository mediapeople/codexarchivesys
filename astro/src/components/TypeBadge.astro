---
import { getTypeLabel } from '../lib/archive';

interface Props {
  type: string;
}

const { type } = Astro.props;

const classMap: Record<string, string> = {
  scroll: 'scroll',
  artifact: 'artifact',
  fieldlog: 'fieldlog',
  codex: 'codex',
  fragment: 'fragment',
  nexus: 'nexus',
  signal: 'signal',
};

const badgeClass = classMap[type] || 'default';
---

<span class={`type-badge ${badgeClass}`}>{getTypeLabel(type)}</span>

<style>
  .type-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 1px 6px;
    font-family: var(--font-ui);
    font-size: 9px;
    line-height: 1.55;
    font-weight: 700;
    letter-spacing: var(--ls-ui);
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.02);
  }

  .scroll {
    border-color: rgba(196, 98, 58, 0.45);
    background: rgba(196, 98, 58, 0.1);
    color: #dfab92;
  }

  .artifact {
    border-color: rgba(201, 150, 58, 0.45);
    background: rgba(201, 150, 58, 0.1);
    color: #e6c27d;
  }

  .fieldlog {
    border-color: rgba(138, 132, 128, 0.4);
    background: rgba(138, 132, 128, 0.12);
    color: var(--ash);
  }

  .codex {
    border-color: rgba(201, 150, 58, 0.45);
    background: rgba(201, 150, 58, 0.12);
    color: var(--gold);
  }

  .fragment {
    border-color: rgba(92, 84, 80, 0.46);
    background: rgba(92, 84, 80, 0.16);
    color: #b8b0ac;
  }

  .nexus {
    border-color: var(--rust);
    background: rgba(196, 98, 58, 0.14);
    color: #efc9ba;
  }

  .signal {
    border-color: rgba(132, 176, 158, 0.56);
    background: rgba(132, 176, 158, 0.12);
    color: #bcd8cb;
  }

  .default {
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--line);
    color: var(--text-dim);
  }
</style>
